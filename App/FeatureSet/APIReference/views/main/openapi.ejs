<main class="py-16">
    <article class="prose ">
        <h1><%= t('pages.openapi.title') %></h1>
        <p class="lead"><%= t('pages.openapi.intro') %></p>
        <p><%= t('pages.openapi.body') %></p>
        <h2 id="importing-spec" class="scroll-mt-24">
            <%= t('pages.openapi.importing') %>
        </h2>
        <div class="grid grid-cols-1 items-start gap-x-16 gap-y-10">
            <div class="[&amp;>:first-child]:mt-0 [&amp;>:last-child]:mb-0">
                <p><%= t('pages.openapi.importingBody') %></p>
                <div class="my-6">
                    <ol class="list-decimal pl-6">
                        <li class="mb-2"><%- t('pages.openapi.step1') %></li>
                        <li class="mb-2"><%- t('pages.openapi.step2') %></li>
                        <li class="mb-2"><%- t('pages.openapi.step3') %></li>
                        <li class="mb-2"><%- t('pages.openapi.step4Prefix') %><code class="inline-code"><%= pageData.hostUrl  %>api/openapi/spec</code></li>
                        <li class="mb-2"><%- t('pages.openapi.step5') %></li>
                    </ol>
                </div>
                <h2 id="spec-url" class="scroll-mt-24">
                    <%= t('pages.openapi.specUrl') %>
                </h2>
                <div class="my-6">
                    <ul role="list"
                        class="m-0  list-none divide-y divide-zinc-900/5 p-0 ">
                        <li class="m-0 px-0 py-4 first:pt-0 last:pb-0">
                            <dl class="m-0 flex flex-wrap items-center gap-x-3 gap-y-2">
                                <dt class="sr-only"><%= t('ui.srEndpoint') %></dt>
                                <dd><code class="inline-code"><%= pageData.hostUrl %>api/openapi/spec</code></dd>
                                <dt class="sr-only"><%= t('ui.srDescription') %></dt>
                                <dd class="w-full flex-none [&amp;>:first-child]:mt-0 [&amp;>:last-child]:mb-0">
                                    <p><%= t('pages.openapi.specUrlDescription') %></p>
                                </dd>
                            </dl>
                        </li>
                    </ul>
                </div>
                <h2 id="benefits" class="scroll-mt-24">
                    <%= t('pages.openapi.benefits') %>
                </h2>
                <div class="my-6">
                    <ul class="list-disc pl-6">
                        <li class="mb-2"><strong><%= t('pages.openapi.benefit1Title') %></strong> <%= t('pages.openapi.benefit1Body') %></li>
                        <li class="mb-2"><strong><%= t('pages.openapi.benefit2Title') %></strong> <%= t('pages.openapi.benefit2Body') %></li>
                        <li class="mb-2"><strong><%= t('pages.openapi.benefit3Title') %></strong> <%= t('pages.openapi.benefit3Body') %></li>
                        <li class="mb-2"><strong><%= t('pages.openapi.benefit4Title') %></strong> <%= t('pages.openapi.benefit4Body') %></li>
                    </ul>
                </div>
            </div>
        </div>
    </article>
</main>
