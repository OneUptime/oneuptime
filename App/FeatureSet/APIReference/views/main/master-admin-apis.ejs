<main class="py-12">
   <article class="prose">
      <!-- Hero Section -->
      <div class="mb-10">
         <div class="flex items-center gap-3 mb-4">
            <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-indigo-600 shadow-lg shadow-indigo-500/30">
               <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
               </svg>
            </div>
            <span class="text-xs font-semibold text-indigo-600 uppercase tracking-wider"><%= t('pages.masterAdminApis.badge') %></span>
         </div>
         <h1 class="font-bold text-3xl text-slate-900 tracking-tight mb-3"><%= t('pages.masterAdminApis.title') %></h1>
         <p class="text-lg text-slate-600 leading-relaxed max-w-2xl"><%= t('pages.masterAdminApis.intro') %></p>
      </div>

      <p class="text-slate-600 leading-relaxed"><%= t('pages.masterAdminApis.body') %></p>

      <div class="my-6 flex gap-3 rounded-xl border border-indigo-500/20 bg-indigo-50/50 p-4">
         <div class="flex-shrink-0">
            <svg viewBox="0 0 16 16" aria-hidden="true" class="h-5 w-5 fill-indigo-500 stroke-white">
               <circle cx="8" cy="8" r="8" stroke-width="0"></circle>
               <path fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 7.75h1.5v3.5"></path>
               <circle cx="8" cy="4" r=".5" fill="none"></circle>
            </svg>
         </div>
         <p class="text-sm text-indigo-900"><%= t('pages.masterAdminApis.selfHostedNote') %></p>
      </div>

      <h2 id="master-api-key" class="scroll-mt-24 text-xl font-semibold text-slate-900 mb-4 mt-12 pt-8 border-t border-slate-200">
         <%= t('pages.masterAdminApis.masterApiKey') %>
      </h2>
      <p class="text-slate-600 leading-relaxed mb-6"><%- t('pages.masterAdminApis.masterApiKeyBody') %></p>

      <ol class="list-decimal pl-5 space-y-2 text-slate-600 leading-relaxed marker:text-slate-400 marker:font-medium">
         <li><%- t('pages.masterAdminApis.keyStep1') %></li>
         <li><%- t('pages.masterAdminApis.keyStep2') %></li>
         <li><%- t('pages.masterAdminApis.keyStep3') %></li>
      </ol>

      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4">
         <div class="flex gap-3">
            <div class="flex-shrink-0">
               <svg class="h-5 w-5 text-amber-500" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
               </svg>
            </div>
            <p class="text-sm text-amber-800"><%= t('pages.masterAdminApis.keyWarning') %></p>
         </div>
      </div>

      <h2 id="authentication" class="scroll-mt-24 text-xl font-semibold text-slate-900 mb-4 mt-12 pt-8 border-t border-slate-200">
         <%= t('pages.masterAdminApis.authentication') %>
      </h2>
      <div class="grid grid-cols-1 items-start gap-x-16 gap-y-10 xl:max-w-none xl:grid-cols-2">
         <div class="[&amp;>:first-child]:mt-0 [&amp;>:last-child]:mb-0">
            <p class="text-slate-600 leading-relaxed"><%- t('pages.masterAdminApis.authenticationBody') %></p>
            <p class="text-slate-600 leading-relaxed"><%- t('pages.masterAdminApis.authenticationSession') %></p>
         </div>
         <div class="[&amp;>:first-child]:mt-0 [&amp;>:last-child]:mb-0 xl:sticky xl:top-24">
            <%- include('../partials/code', {
               title: t('pages.masterAdminApis.exampleRequestTitle'),
               requestUrl: "",
               requestType: "",
               code: "curl --header \"ApiKey: {master-api-key}\" \\\n  " + pageData.hostUrl + "api/admin/health/overview"
            }) -%>
         </div>
      </div>

      <h2 id="endpoints" class="scroll-mt-24 text-xl font-semibold text-slate-900 mb-4 mt-12 pt-8 border-t border-slate-200">
         <%= t('pages.masterAdminApis.endpoints') %>
      </h2>
      <p class="text-slate-600 leading-relaxed mb-6"><%- t('pages.masterAdminApis.endpointsBody', { basePath: pageData.basePath }) %></p>

      <div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
         <ul role="list" class="m-0 list-none divide-y divide-slate-100 p-0">
            <% pageData.endpoints.forEach(function(endpoint){ %>
            <li class="m-0 px-5 py-4">
               <dl class="m-0 flex flex-wrap items-center gap-x-3 gap-y-2">
                  <dt class="sr-only"><%= t('ui.srEndpoint') %></dt>
                  <dd><code class="inline-flex items-center rounded-md bg-emerald-50 px-2 py-1 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20">GET</code></dd>
                  <dd><code class="text-sm font-mono text-slate-900 break-all"><%= pageData.basePath %><%= endpoint.path %></code></dd>
                  <dd>
                     <% if(endpoint.isEnterpriseEdition){ %>
                     <span class="inline-flex items-center rounded-md bg-violet-50 px-2 py-1 text-xs font-medium text-violet-700 ring-1 ring-inset ring-violet-600/20"><%= t('pages.masterAdminApis.enterpriseOnly') %></span>
                     <% } else { %>
                     <span class="inline-flex items-center rounded-md bg-slate-50 px-2 py-1 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-500/20"><%= t('pages.masterAdminApis.allEditions') %></span>
                     <% } %>
                  </dd>
                  <dd class="w-full flex-none text-sm text-slate-600 mt-1"><%= t('pages.masterAdminApis.' + endpoint.key + 'Desc') %></dd>
               </dl>
            </li>
            <% }) %>
         </ul>
      </div>

      <p class="text-slate-600 leading-relaxed mt-6"><%- t('pages.masterAdminApis.queueNamesBody') %></p>

      <h2 id="editions" class="scroll-mt-24 text-xl font-semibold text-slate-900 mb-4 mt-12 pt-8 border-t border-slate-200">
         <%= t('pages.masterAdminApis.editions') %>
      </h2>
      <p class="text-slate-600 leading-relaxed"><%- t('pages.masterAdminApis.editionsBody') %></p>
      <p class="text-slate-600 leading-relaxed"><%- t('pages.masterAdminApis.editionsCommunityBody') %></p>

      <h2 id="example-response" class="scroll-mt-24 text-xl font-semibold text-slate-900 mb-4 mt-12 pt-8 border-t border-slate-200">
         <%= t('pages.masterAdminApis.exampleResponse') %>
      </h2>
      <div class="grid grid-cols-1 items-start gap-x-16 gap-y-10 xl:max-w-none xl:grid-cols-2">
         <div class="[&amp;>:first-child]:mt-0 [&amp;>:last-child]:mb-0">
            <p class="text-slate-600 leading-relaxed"><%- t('pages.masterAdminApis.exampleResponseBody') %></p>
            <p class="text-slate-600 leading-relaxed"><%= t('pages.masterAdminApis.exampleResponseNote') %></p>
         </div>
         <div class="[&amp;>:first-child]:mt-0 [&amp;>:last-child]:mb-0 xl:sticky xl:top-24">
            <%- include('../partials/code', {
               title: t('pages.masterAdminApis.exampleResponseTitle'),
               requestUrl: pageData.basePath + "/overview",
               requestType: "GET",
               code: JSON.stringify({
                  summary: {
                     postgres: { connected: true, databaseSizeInBytes: 1073741824 },
                     clickhouse: { connected: true },
                     redis: { connected: true, usedMemoryInBytes: 52428800, maxMemoryInBytes: 268435456 },
                     queues: {
                        totalQueues: 4,
                        healthyQueues: 4,
                        failingQueues: 0,
                        unavailableQueues: 0,
                        failedJobs: 0,
                        waitingJobs: 12,
                        delayedJobs: 3
                     }
                  }
               }, null, 2)
            }) -%>
         </div>
      </div>

      <h2 id="sensitive-data" class="scroll-mt-24 text-xl font-semibold text-slate-900 mb-4 mt-12 pt-8 border-t border-slate-200">
         <%= t('pages.masterAdminApis.sensitiveData') %>
      </h2>
      <p class="text-slate-600 leading-relaxed"><%- t('pages.masterAdminApis.sensitiveDataBody') %></p>

      <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4">
         <div class="flex gap-3">
            <div class="flex-shrink-0">
               <svg class="h-5 w-5 text-amber-500" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
               </svg>
            </div>
            <p class="text-sm text-amber-800"><%= t('pages.masterAdminApis.sensitiveDataWarning') %></p>
         </div>
      </div>

      <h2 id="not-available" class="scroll-mt-24 text-xl font-semibold text-slate-900 mb-4 mt-12 pt-8 border-t border-slate-200">
         <%= t('pages.masterAdminApis.notAvailable') %>
      </h2>
      <p class="text-slate-600 leading-relaxed"><%- t('pages.masterAdminApis.notAvailableBody') %></p>
   </article>
</main>
