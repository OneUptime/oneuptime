{{> Start this}}

<!-- Preheader (hidden inbox preview) -->
<div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#f3f4f6;opacity:0;">{{statusPageName}} uptime report — {{report.averageUptimePercent}} average uptime over {{report.reportDates}}.</div>

{{> CustomLogo this}}

{{> EmailTitle title=(concat "Uptime Report: " statusPageName) }}

{{#ifCond hasResources "true"}}
{{> InfoBlock info=(concat "Here is your status summary for the last " report.reportDates) }}

<!-- Hero Stat: Average Uptime -->
<table class="st-Copy st-Width st-Width--mobile" border="0" cellpadding="0" cellspacing="0" width="600" style="min-width: 600px;">
  <tbody>
    <tr>
      <td class="st-Spacer st-Spacer--gutter" width="64" style="border:0;margin:0;padding:0;font-size:1px;line-height:1px;mso-line-height-rule:exactly;"><div class="st-Spacer st-Spacer--filler"></div></td>
      <td style="border:0;margin:0;padding:0;">
        <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#f1f5f9" style="background-color:#f1f5f9;border:1px solid #e2e8f0;border-radius:12px;">
          <tbody>
            <tr>
              <td align="center" style="padding:28px 24px 26px 24px;">
                <p style="Margin:0 0 6px 0;font-size:11px;font-weight:600;letter-spacing:0.6px;text-transform:uppercase;color:#64748b;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Ubuntu,sans-serif;">Average Uptime</p>
                <p style="Margin:0;font-size:52px;line-height:56px;font-weight:700;color:#1a1a2e;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Ubuntu,sans-serif;">{{report.averageUptimePercent}}</p>
                <p style="Margin:10px 0 0 0;font-size:13px;line-height:18px;color:#64748b;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Ubuntu,sans-serif;">across {{report.reportDates}}</p>
              </td>
            </tr>
          </tbody>
        </table>
      </td>
      <td class="st-Spacer st-Spacer--gutter" width="64" style="border:0;margin:0;padding:0;font-size:1px;line-height:1px;mso-line-height-rule:exactly;"><div class="st-Spacer st-Spacer--filler"></div></td>
    </tr>
    <tr>
      <td class="st-Spacer st-Spacer--stacked" colspan="3" height="14" style="border:0;margin:0;padding:0;font-size:1px;line-height:1px;mso-line-height-rule:exactly;"><div class="st-Spacer st-Spacer--filler"></div></td>
    </tr>
  </tbody>
</table>
<!-- /Hero Stat -->

<!-- Supporting Stats Strip (Downtime · Incidents · Resources) -->
<table class="st-Copy st-Width st-Width--mobile" border="0" cellpadding="0" cellspacing="0" width="600" style="min-width: 600px;">
  <tbody>
    <tr>
      <td class="st-Spacer st-Spacer--gutter" width="64" style="border:0;margin:0;padding:0;font-size:1px;line-height:1px;mso-line-height-rule:exactly;"><div class="st-Spacer st-Spacer--filler"></div></td>
      <td style="border:0;margin:0;padding:0;">
        <table border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#f1f5f9" style="background-color:#f1f5f9;border:1px solid #e2e8f0;border-radius:12px;">
          <tbody>
            <tr>
              <td width="33%" align="center" valign="middle" style="padding:18px 8px;border-right:1px solid #e2e8f0;">
                <p style="Margin:0;font-size:24px;line-height:28px;font-weight:700;color:#1a1a2e;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Ubuntu,sans-serif;">{{report.totalDowntimeInHoursAndMinutes}}</p>
                <p style="Margin:6px 0 0 0;font-size:11px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;color:#64748b;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Ubuntu,sans-serif;">Downtime</p>
              </td>
              <td width="33%" align="center" valign="middle" style="padding:18px 8px;border-right:1px solid #e2e8f0;">
                <p style="Margin:0;font-size:24px;line-height:28px;font-weight:700;color:#1a1a2e;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Ubuntu,sans-serif;">{{report.totalIncidents}}</p>
                <p style="Margin:6px 0 0 0;font-size:11px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;color:#64748b;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Ubuntu,sans-serif;">Incidents</p>
              </td>
              <td width="34%" align="center" valign="middle" style="padding:18px 8px;">
                <p style="Margin:0;font-size:24px;line-height:28px;font-weight:700;color:#1a1a2e;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Ubuntu,sans-serif;">{{report.totalResources}}</p>
                <p style="Margin:6px 0 0 0;font-size:11px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;color:#64748b;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Ubuntu,sans-serif;">Resources</p>
              </td>
            </tr>
          </tbody>
        </table>
      </td>
      <td class="st-Spacer st-Spacer--gutter" width="64" style="border:0;margin:0;padding:0;font-size:1px;line-height:1px;mso-line-height-rule:exactly;"><div class="st-Spacer st-Spacer--filler"></div></td>
    </tr>
    <tr>
      <td class="st-Spacer st-Spacer--stacked" colspan="3" height="22" style="border:0;margin:0;padding:0;font-size:1px;line-height:1px;mso-line-height-rule:exactly;"><div class="st-Spacer st-Spacer--filler"></div></td>
    </tr>
  </tbody>
</table>
<!-- /Supporting Stats Strip -->

{{> TitleBlock title="Per-resource breakdown"}}

<!-- Per-resource Table -->
<table class="st-Copy st-Width st-Width--mobile" border="0" cellpadding="0" cellspacing="0" width="600" style="min-width: 600px;">
  <tbody>
    <tr>
      <td class="st-Spacer st-Spacer--gutter" width="64" style="border:0;margin:0;padding:0;font-size:1px;line-height:1px;mso-line-height-rule:exactly;"><div class="st-Spacer st-Spacer--filler"></div></td>
      <td style="border:0;margin:0;padding:0;">
        <table border="0" cellpadding="0" cellspacing="0" width="100%" style="border-collapse:separate;border-spacing:0;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Ubuntu,sans-serif;">
          <thead>
            <tr>
              <th align="left" bgcolor="#1a1a2e" style="background-color:#1a1a2e;color:#ffffff;padding:12px 14px;font-size:11px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;text-align:left;">Resource</th>
              <th align="right" bgcolor="#1a1a2e" style="background-color:#1a1a2e;color:#ffffff;padding:12px 14px;font-size:11px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;text-align:right;">Uptime</th>
              <th align="right" bgcolor="#1a1a2e" style="background-color:#1a1a2e;color:#ffffff;padding:12px 14px;font-size:11px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;text-align:right;">Downtime</th>
              <th align="right" bgcolor="#1a1a2e" style="background-color:#1a1a2e;color:#ffffff;padding:12px 14px;font-size:11px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;text-align:right;">Incidents</th>
            </tr>
          </thead>
          <tbody>
            {{#each report.resources}}
            <tr bgcolor="{{#if @odd}}#f0f3f9{{else}}#ffffff{{/if}}" style="background-color:{{#if @odd}}#f0f3f9{{else}}#ffffff{{/if}};">
              <td align="left" style="padding:12px 14px;border-top:1px solid #e5e8f0;font-size:14px;color:#374151;font-weight:500;">{{this.resourceName}}</td>
              <td align="right" style="padding:12px 14px;border-top:1px solid #e5e8f0;font-size:14px;color:#1e293b;font-weight:600;text-align:right;">{{this.uptimePercentAsString}}</td>
              <td align="right" style="padding:12px 14px;border-top:1px solid #e5e8f0;font-size:14px;color:#374151;text-align:right;">{{this.downtimeInHoursAndMinutes}}</td>
              <td align="right" style="padding:12px 14px;border-top:1px solid #e5e8f0;font-size:14px;color:#1e293b;font-weight:600;text-align:right;">{{this.totalIncidentCount}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </td>
      <td class="st-Spacer st-Spacer--gutter" width="64" style="border:0;margin:0;padding:0;font-size:1px;line-height:1px;mso-line-height-rule:exactly;"><div class="st-Spacer st-Spacer--filler"></div></td>
    </tr>
    <tr>
      <td class="st-Spacer st-Spacer--stacked" colspan="3" height="22" style="border:0;margin:0;padding:0;font-size:1px;line-height:1px;mso-line-height-rule:exactly;"><div class="st-Spacer st-Spacer--filler"></div></td>
    </tr>
  </tbody>
</table>
<!-- /Per-resource Table -->
{{/ifCond}}

{{#ifCond hasResources "false"}}
{{> InfoBlock info="No resources have been added to this status page yet, so there is nothing to report this period. Once you add resources, their uptime and incident history will appear in future reports."}}
{{/ifCond}}

{{#if detailsUrl}}
{{> ButtonBlock buttonUrl=detailsUrl buttonText="View Full Status Page"}}
{{else}}
{{> ButtonBlock buttonUrl=statusPageUrl buttonText="View Full Status Page"}}
{{/if}}

{{> VerticalSpace this}}

{{#if subscriberEmailNotificationFooterText}}
{{> InfoBlock info=subscriberEmailNotificationFooterText }}
{{/if}}

{{#if unsubscribeUrl}}
{{> UnsubscribeBlock this}}
{{/if}}

{{> Footer this}}

{{> End this}}
