<!DOCTYPE html>
<html lang="en" id="home">

<meta http-equiv="content-type" content="text/html;charset=utf-8" />

<head>
  <title>OneUptime | Cloud Monitoring - AWS, Google Cloud & Azure Observability</title>
  <meta name="description"
    content="Monitor AWS, Google Cloud, and Azure with OpenTelemetry. Auto-discovered cloud environments, real-time resource metrics, logs, traces, and alerting across every region and account. Open source.">
  <%- include('head', {
    enableGoogleTagManager: typeof enableGoogleTagManager !== 'undefined' ? enableGoogleTagManager : false
}) -%>
</head>

<body>
  <%- include('nav') -%>

  <main id="main-content">
    <!-- Hero Section -->
    <div class="relative isolate overflow-hidden bg-white" id="cloud-hero-section">
      <!-- Subtle grid pattern background -->
      <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#f0f0f0_1px,transparent_1px),linear-gradient(to_bottom,#f0f0f0_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)]"></div>

      <!-- Grid glow effect that follows cursor -->
      <div id="cloud-grid-glow" class="absolute inset-0 -z-9 pointer-events-none" style="opacity: 0; transition: opacity 0.3s ease-out; background: linear-gradient(to right, rgba(14, 165, 233, 0.3) 1px, transparent 1px), linear-gradient(to bottom, rgba(14, 165, 233, 0.3) 1px, transparent 1px); background-size: 4rem 4rem; -webkit-mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%); mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%);"></div>

      <div class="py-20 sm:py-28 lg:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-3xl text-center">
            <!-- Minimal badge -->
            <p class="text-sm font-medium text-sky-600 mb-4">OpenTelemetry Native Cloud Monitoring</p>

            <h1 class="text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
              Your whole cloud, one pane of glass
            </h1>
            <p class="mt-6 text-lg leading-8 text-gray-600 max-w-2xl mx-auto">
              Bring AWS, Google Cloud, and Azure telemetry into OneUptime over OpenTelemetry. Auto-discovered environments, real-time resource metrics, logs, and traces — correlated across every region and account you run.
            </p>

            <div class="mt-10 flex items-center justify-center gap-x-6">
              <a href="/accounts/register"
                class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-800 transition-colors">
                Get started
              </a>
              <a href="/enterprise/demo" class="text-sm font-semibold text-gray-900 hover:text-gray-600 transition-colors">
                Request demo <span aria-hidden="true">&rarr;</span>
              </a>
            </div>

            <!-- Subtle feature list -->
            <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-gray-500">
              <span>AWS</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Google Cloud</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Azure</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Multi-account</span>
            </div>
          </div>

          <!-- Hero visual - Cloud overview mockup -->
          <div class="mt-16 sm:mt-20">
            <div class="relative mx-auto max-w-5xl">
              <div class="rounded-xl bg-gray-900/5 p-1.5 ring-1 ring-gray-900/10">
                <div class="rounded-lg bg-white shadow-lg overflow-hidden">
                  <!-- Header bar -->
                  <div class="bg-gray-50 px-6 py-3 flex items-center justify-between border-b border-gray-200">
                    <div class="flex items-center gap-3">
                      <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-red-400"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                        <div class="w-3 h-3 rounded-full bg-green-400"></div>
                      </div>
                      <div class="flex items-center gap-2">
                        <%- include('./Partials/icons/cloud', {iconClass: 'h-4 w-4'}) %>
                        <span class="text-sm text-gray-700 font-semibold">Cloud Environments</span>
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <div class="flex items-center gap-1.5 px-2.5 py-1 bg-white rounded-md border border-gray-200 text-xs text-gray-500">
                        <svg class="h-3 w-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Last 1 hour
                      </div>
                      <span class="flex items-center gap-1.5 px-2.5 py-1 bg-emerald-50 rounded-md text-xs font-medium text-emerald-600 border border-emerald-200">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                        3 clouds · 6 regions
                      </span>
                    </div>
                  </div>

                  <!-- Dashboard content -->
                  <div class="p-5">
                    <!-- Top stats row -->
                    <div class="grid grid-cols-5 gap-3 mb-5">
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">Environments</div>
                        <div class="text-xl font-bold text-gray-900">9</div>
                        <div class="text-[10px] text-gray-500 font-medium mt-1">across 3 clouds</div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">Instances</div>
                        <div class="text-xl font-bold text-gray-900">214</div>
                        <div class="text-[10px] text-emerald-500 font-medium mt-1">211 healthy</div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">Avg CPU</div>
                        <div class="text-xl font-bold text-gray-900">48%</div>
                        <div class="w-full bg-gray-100 rounded-full h-1.5 mt-2">
                          <div class="bg-sky-400 h-1.5 rounded-full" style="width: 48%"></div>
                        </div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">Avg Memory</div>
                        <div class="text-xl font-bold text-gray-900">66%</div>
                        <div class="w-full bg-gray-100 rounded-full h-1.5 mt-2">
                          <div class="bg-violet-400 h-1.5 rounded-full" style="width: 66%"></div>
                        </div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">Alerts</div>
                        <div class="text-xl font-bold text-gray-900">2</div>
                        <div class="text-[10px] text-amber-500 font-medium mt-1">active</div>
                      </div>
                    </div>

                    <!-- Charts row -->
                    <div class="grid grid-cols-3 gap-3 mb-5">
                      <div class="col-span-2 bg-white rounded-lg border border-gray-200 shadow-sm p-4">
                        <div class="flex items-center justify-between mb-4">
                          <div>
                            <div class="text-sm font-semibold text-gray-800">Fleet Resource Usage</div>
                            <div class="text-[10px] text-gray-400 mt-0.5">CPU and Memory across all clouds</div>
                          </div>
                          <div class="flex items-center gap-3">
                            <div class="flex items-center gap-1">
                              <span class="w-2 h-2 rounded-full bg-sky-500"></span>
                              <span class="text-[10px] text-gray-500">CPU</span>
                            </div>
                            <div class="flex items-center gap-1">
                              <span class="w-2 h-2 rounded-full bg-violet-500"></span>
                              <span class="text-[10px] text-gray-500">Memory</span>
                            </div>
                          </div>
                        </div>
                        <svg viewBox="0 0 400 100" class="w-full h-24">
                          <defs>
                            <linearGradient id="cloudCpuGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                              <stop offset="0%" style="stop-color:#0ea5e9;stop-opacity:0.2"/>
                              <stop offset="100%" style="stop-color:#0ea5e9;stop-opacity:0"/>
                            </linearGradient>
                            <linearGradient id="cloudMemGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                              <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:0.15"/>
                              <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:0"/>
                            </linearGradient>
                          </defs>
                          <line x1="0" y1="25" x2="400" y2="25" stroke="#f3f4f6" stroke-width="1"/>
                          <line x1="0" y1="50" x2="400" y2="50" stroke="#f3f4f6" stroke-width="1"/>
                          <line x1="0" y1="75" x2="400" y2="75" stroke="#f3f4f6" stroke-width="1"/>
                          <path d="M0,62 L25,58 L50,55 L75,57 L100,52 L125,54 L150,48 L175,50 L200,46 L225,49 L250,44 L275,47 L300,43 L325,46 L350,42 L375,45 L400,41 L400,100 L0,100 Z" fill="url(#cloudCpuGrad)"/>
                          <path d="M0,62 L25,58 L50,55 L75,57 L100,52 L125,54 L150,48 L175,50 L200,46 L225,49 L250,44 L275,47 L300,43 L325,46 L350,42 L375,45 L400,41" fill="none" stroke="#0ea5e9" stroke-width="2" stroke-linecap="round"/>
                          <path d="M0,38 L25,36 L50,34 L75,32 L100,31 L125,30 L150,28 L175,30 L200,27 L225,29 L250,26 L275,28 L300,25 L325,27 L350,24 L375,26 L400,23 L400,100 L0,100 Z" fill="url(#cloudMemGrad)"/>
                          <path d="M0,38 L25,36 L50,34 L75,32 L100,31 L125,30 L150,28 L175,30 L200,27 L225,29 L250,26 L275,28 L300,25 L325,27 L350,24 L375,26 L400,23" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round"/>
                          <text x="2" y="23" fill="#9ca3af" font-size="8">75%</text>
                          <text x="2" y="48" fill="#9ca3af" font-size="8">50%</text>
                          <text x="2" y="73" fill="#9ca3af" font-size="8">25%</text>
                        </svg>
                      </div>

                      <!-- Region breakdown -->
                      <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-4">
                        <div class="text-sm font-semibold text-gray-800 mb-1">By Region</div>
                        <div class="text-[10px] text-gray-400 mb-4">Instances per region</div>
                        <div class="space-y-3">
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">us-east-1</span>
                              <span class="text-[10px] text-gray-500">84</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-sky-400 h-1.5 rounded-full" style="width:82%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">us-central1</span>
                              <span class="text-[10px] text-gray-500">52</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-sky-400 h-1.5 rounded-full" style="width:52%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">eu-west-1</span>
                              <span class="text-[10px] text-gray-500">46</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-sky-400 h-1.5 rounded-full" style="width:46%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">westeurope</span>
                              <span class="text-[10px] text-gray-500">32</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-sky-400 h-1.5 rounded-full" style="width:32%"></div></div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Environments table -->
                    <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                      <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                        <span class="text-xs font-semibold text-gray-700">Cloud environments</span>
                        <span class="text-[10px] text-gray-400">9 total</span>
                      </div>
                      <table class="w-full text-xs">
                        <thead class="bg-white border-b border-gray-100">
                          <tr>
                            <th class="px-4 py-2 text-left text-[10px] font-semibold uppercase tracking-wider text-gray-500">Platform</th>
                            <th class="px-4 py-2 text-left text-[10px] font-semibold uppercase tracking-wider text-gray-500">Account / Project</th>
                            <th class="px-4 py-2 text-left text-[10px] font-semibold uppercase tracking-wider text-gray-500">Region</th>
                            <th class="px-4 py-2 text-right text-[10px] font-semibold uppercase tracking-wider text-gray-500">Instances</th>
                            <th class="px-4 py-2 text-right text-[10px] font-semibold uppercase tracking-wider text-gray-500">CPU</th>
                          </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                          <tr>
                            <td class="px-4 py-2 font-medium text-gray-900">AWS</td>
                            <td class="px-4 py-2 font-mono text-gray-500">4109-2277-8841</td>
                            <td class="px-4 py-2 font-mono text-gray-500">us-east-1</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">84</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">51%</td>
                          </tr>
                          <tr>
                            <td class="px-4 py-2 font-medium text-gray-900">Google Cloud</td>
                            <td class="px-4 py-2 font-mono text-gray-500">prod-platform</td>
                            <td class="px-4 py-2 font-mono text-gray-500">us-central1</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">52</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">44%</td>
                          </tr>
                          <tr>
                            <td class="px-4 py-2 font-medium text-gray-900">Azure</td>
                            <td class="px-4 py-2 font-mono text-gray-500">core-prod-sub</td>
                            <td class="px-4 py-2 font-mono text-gray-500">westeurope</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">32</td>
                            <td class="px-4 py-2 text-right font-mono text-amber-600">79%</td>
                          </tr>
                          <tr>
                            <td class="px-4 py-2 font-medium text-gray-900">AWS</td>
                            <td class="px-4 py-2 font-mono text-gray-500">4109-2277-8841</td>
                            <td class="px-4 py-2 font-mono text-gray-500">eu-west-1</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">46</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">38%</td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- How It Works Section -->
    <div class="relative bg-gray-50 py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <p class="text-sm font-medium text-sky-600 uppercase tracking-wide mb-3">How It Works</p>
          <h2 class="text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl">
            One collector. Every cloud you run.
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            Environments are grouped by the OTel <code class="text-sm bg-gray-100 px-1.5 py-0.5 rounded">cloud.platform</code>, account, and region attributes — captured automatically by resource detectors.
          </p>
        </div>

        <div class="mx-auto max-w-5xl">
          <!-- Connecting line for desktop -->
          <div class="hidden lg:block relative">
            <div class="absolute top-8 left-[calc(12.5%+24px)] right-[calc(12.5%+24px)] h-px bg-sky-200"></div>
          </div>

          <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Step 1 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-sky-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-sky-600 ring-2 ring-sky-600">1</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Deploy the collector</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Run the OpenTelemetry Collector or the OneUptime Kubernetes agent in each cloud and account you operate.</p>
            </div>

            <!-- Step 2 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-sky-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-sky-600 ring-2 ring-sky-600">2</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Auto-detect metadata</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Resource detectors read cloud, account, and region straight from EC2, GCP, and Azure instance metadata.</p>
            </div>

            <!-- Step 3 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-sky-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-sky-600 ring-2 ring-sky-600">3</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Environments appear</h3>
              <p class="text-sm text-gray-600 leading-relaxed">A cloud environment is created per platform + account + region. No manual setup, no inventory to maintain.</p>
            </div>

            <!-- Step 4 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-sky-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-sky-600 ring-2 ring-sky-600">4</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Alert &amp; correlate</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Alert on resource saturation and jump from a metric straight to the logs and traces behind it.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Why OneUptime Section -->
    <div class="relative bg-white py-24 sm:py-32 overflow-hidden">

      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <!-- Section header -->
        <div class="mx-auto max-w-2xl text-center mb-20">
          <div class="inline-flex items-center gap-2 rounded-full bg-sky-50 px-4 py-1.5 text-sm font-medium text-sky-700 ring-1 ring-inset ring-sky-600/20 mb-6">
            <svg class="h-4 w-4 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
            </svg>
            <span class="text-sm font-medium text-sky-700">Why OneUptime for Cloud</span>
          </div>
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl">
            Multi-cloud observability without the silos
          </h2>
          <p class="mt-6 text-lg leading-8 text-gray-600">
            Whether you run one account or a hundred, OneUptime brings every cloud into a single, consistent view — resource metrics, logs, traces, and alerting that don't care which provider you chose.
          </p>
        </div>

        <!-- Feature blocks -->
        <div class="space-y-24">

          <!-- Feature 1: Multi-cloud unified view -->
          <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
            <div class="relative">
              <div class="flex items-center gap-4 mb-6">
