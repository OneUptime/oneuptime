<!DOCTYPE html>
<html lang="en" id="home">

<meta http-equiv="content-type" content="text/html;charset=utf-8" />

<head>
  <title>OneUptime | Real User Monitoring (RUM) - Web Vitals, Sessions & Errors</title>
  <meta name="description"
    content="Real User Monitoring for browser and mobile apps with the OpenTelemetry Web SDK. Core Web Vitals, page views, JavaScript errors, and real user sessions — correlated with backend traces. Open source.">
  <%- include('head', {
    enableGoogleTagManager: typeof enableGoogleTagManager !== 'undefined' ? enableGoogleTagManager : false
}) -%>
</head>

<body>
  <%- include('nav') -%>

  <main id="main-content">
    <!-- Hero Section -->
    <div class="relative isolate overflow-hidden bg-white" id="rum-hero-section">
      <!-- Subtle grid pattern background -->
      <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#f0f0f0_1px,transparent_1px),linear-gradient(to_bottom,#f0f0f0_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)]"></div>

      <!-- Grid glow effect that follows cursor -->
      <div id="rum-grid-glow" class="absolute inset-0 -z-9 pointer-events-none" style="opacity: 0; transition: opacity 0.3s ease-out; background: linear-gradient(to right, rgba(99, 102, 241, 0.3) 1px, transparent 1px), linear-gradient(to bottom, rgba(99, 102, 241, 0.3) 1px, transparent 1px); background-size: 4rem 4rem; -webkit-mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%); mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%);"></div>

      <div class="py-20 sm:py-28 lg:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-3xl text-center">
            <!-- Minimal badge -->
            <p class="text-sm font-medium text-indigo-600 mb-4">OpenTelemetry Native Real User Monitoring</p>

            <h1 class="text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
              See your app through your users' eyes
            </h1>
            <p class="mt-6 text-lg leading-8 text-gray-600 max-w-2xl mx-auto">
              Instrument your browser and mobile apps with the OpenTelemetry Web SDK. Page loads, Core Web Vitals, JavaScript errors, and real user sessions — correlated with the backend traces behind every click.
            </p>

            <div class="mt-10 flex items-center justify-center gap-x-6">
              <a href="/accounts/register"
                class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-800 transition-colors">
                Get started
              </a>
              <a href="/enterprise/demo" class="text-sm font-semibold text-gray-900 hover:text-gray-600 transition-colors">
                Request demo <span aria-hidden="true">&rarr;</span>
              </a>
            </div>

            <!-- Subtle feature list -->
            <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-gray-500">
              <span>Core Web Vitals</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Page views</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>JS errors</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Session traces</span>
            </div>
          </div>

          <!-- Hero visual - RUM overview mockup -->
          <div class="mt-16 sm:mt-20">
            <div class="relative mx-auto max-w-5xl">
              <div class="rounded-xl bg-gray-900/5 p-1.5 ring-1 ring-gray-900/10">
                <div class="rounded-lg bg-white shadow-lg overflow-hidden">
                  <!-- Header bar -->
                  <div class="bg-gray-50 px-6 py-3 flex items-center justify-between border-b border-gray-200">
                    <div class="flex items-center gap-3">
                      <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-red-400"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                        <div class="w-3 h-3 rounded-full bg-green-400"></div>
                      </div>
                      <div class="flex items-center gap-2">
                        <%- include('./Partials/icons/rum', {iconClass: 'h-4 w-4'}) %>
                        <span class="text-sm text-gray-700 font-semibold">Real User Monitoring</span>
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <div class="flex items-center gap-1.5 px-2.5 py-1 bg-white rounded-md border border-gray-200 text-xs text-gray-500">
                        <svg class="h-3 w-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Last 24 hours
                      </div>
                      <span class="flex items-center gap-1.5 px-2.5 py-1 bg-emerald-50 rounded-md text-xs font-medium text-emerald-600 border border-emerald-200">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                        web-app
                      </span>
                    </div>
                  </div>

                  <!-- Dashboard content -->
                  <div class="p-5">
                    <!-- Top stats row -->
                    <div class="grid grid-cols-5 gap-3 mb-5">
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">Page views</div>
                        <div class="text-xl font-bold text-gray-900">1.2M</div>
                        <div class="text-[10px] text-emerald-500 font-medium mt-1">+6% vs prev</div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">LCP (p75)</div>
                        <div class="text-xl font-bold text-gray-900">1.9s</div>
                        <div class="text-[10px] text-emerald-500 font-medium mt-1">Good</div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">INP (p75)</div>
                        <div class="text-xl font-bold text-gray-900">182ms</div>
                        <div class="text-[10px] text-amber-500 font-medium mt-1">Needs work</div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">CLS (p75)</div>
                        <div class="text-xl font-bold text-gray-900">0.04</div>
                        <div class="text-[10px] text-emerald-500 font-medium mt-1">Good</div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">JS errors</div>
                        <div class="text-xl font-bold text-gray-900">0.6%</div>
                        <div class="w-full bg-gray-100 rounded-full h-1.5 mt-2">
                          <div class="bg-amber-400 h-1.5 rounded-full" style="width: 6%"></div>
                        </div>
                      </div>
                    </div>

                    <!-- Charts row -->
                    <div class="grid grid-cols-3 gap-3 mb-5">
                      <div class="col-span-2 bg-white rounded-lg border border-gray-200 shadow-sm p-4">
                        <div class="flex items-center justify-between mb-4">
                          <div>
                            <div class="text-sm font-semibold text-gray-800">Page Load &amp; Largest Contentful Paint</div>
                            <div class="text-[10px] text-gray-400 mt-0.5">p75 over time</div>
                          </div>
                          <div class="flex items-center gap-3">
                            <div class="flex items-center gap-1">
                              <span class="w-2 h-2 rounded-full bg-indigo-500"></span>
                              <span class="text-[10px] text-gray-500">Load</span>
                            </div>
                            <div class="flex items-center gap-1">
                              <span class="w-2 h-2 rounded-full bg-fuchsia-500"></span>
                              <span class="text-[10px] text-gray-500">LCP</span>
                            </div>
                          </div>
                        </div>
                        <svg viewBox="0 0 400 100" class="w-full h-24">
                          <defs>
                            <linearGradient id="rumLoadGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                              <stop offset="0%" style="stop-color:#6366f1;stop-opacity:0.2"/>
                              <stop offset="100%" style="stop-color:#6366f1;stop-opacity:0"/>
                            </linearGradient>
                          </defs>
                          <line x1="0" y1="25" x2="400" y2="25" stroke="#f3f4f6" stroke-width="1"/>
                          <line x1="0" y1="50" x2="400" y2="50" stroke="#f3f4f6" stroke-width="1"/>
                          <line x1="0" y1="75" x2="400" y2="75" stroke="#f3f4f6" stroke-width="1"/>
                          <path d="M0,52 L25,50 L50,54 L75,48 L100,52 L125,45 L150,49 L175,44 L200,47 L225,42 L250,46 L275,40 L300,44 L325,39 L350,43 L375,38 L400,42 L400,100 L0,100 Z" fill="url(#rumLoadGrad)"/>
                          <path d="M0,52 L25,50 L50,54 L75,48 L100,52 L125,45 L150,49 L175,44 L200,47 L225,42 L250,46 L275,40 L300,44 L325,39 L350,43 L375,38 L400,42" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round"/>
                          <path d="M0,62 L25,60 L50,63 L75,58 L100,61 L125,56 L150,59 L175,54 L200,57 L225,53 L250,56 L275,51 L300,55 L325,50 L350,54 L375,49 L400,53" fill="none" stroke="#d946ef" stroke-width="2" stroke-dasharray="3 3" stroke-linecap="round"/>
                        </svg>
                      </div>

                      <!-- Web Vitals panel -->
                      <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-4">
                        <div class="text-sm font-semibold text-gray-800 mb-1">Core Web Vitals</div>
                        <div class="text-[10px] text-gray-400 mb-4">p75 · last 24h</div>
                        <div class="space-y-3">
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-medium text-gray-600">LCP</span>
                              <span class="text-[10px] text-emerald-600">1.9s</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-emerald-400 h-1.5 rounded-full" style="width:48%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-medium text-gray-600">INP</span>
                              <span class="text-[10px] text-amber-600">182ms</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-amber-400 h-1.5 rounded-full" style="width:62%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-medium text-gray-600">CLS</span>
                              <span class="text-[10px] text-emerald-600">0.04</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-emerald-400 h-1.5 rounded-full" style="width:18%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-medium text-gray-600">FCP</span>
                              <span class="text-[10px] text-emerald-600">1.2s</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-emerald-400 h-1.5 rounded-full" style="width:32%"></div></div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Pages table -->
                    <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                      <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                        <span class="text-xs font-semibold text-gray-700">Pages by views</span>
                        <span class="text-[10px] text-gray-400">214 routes</span>
                      </div>
                      <table class="w-full text-xs">
                        <thead class="bg-white border-b border-gray-100">
                          <tr>
                            <th class="px-4 py-2 text-left text-[10px] font-semibold uppercase tracking-wider text-gray-500">Route</th>
                            <th class="px-4 py-2 text-right text-[10px] font-semibold uppercase tracking-wider text-gray-500">Views</th>
                            <th class="px-4 py-2 text-right text-[10px] font-semibold uppercase tracking-wider text-gray-500">LCP p75</th>
                            <th class="px-4 py-2 text-right text-[10px] font-semibold uppercase tracking-wider text-gray-500">Errors</th>
                          </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                          <tr>
                            <td class="px-4 py-2 font-mono text-gray-900">/</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">412k</td>
                            <td class="px-4 py-2 text-right font-mono text-emerald-600">1.4s</td>
                            <td class="px-4 py-2 text-right font-mono text-emerald-600">0.2%</td>
                          </tr>
                          <tr>
                            <td class="px-4 py-2 font-mono text-gray-900">/product</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">286k</td>
                            <td class="px-4 py-2 text-right font-mono text-emerald-600">2.0s</td>
                            <td class="px-4 py-2 text-right font-mono text-emerald-600">0.4%</td>
                          </tr>
                          <tr>
                            <td class="px-4 py-2 font-mono text-gray-900">/checkout</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">94k</td>
                            <td class="px-4 py-2 text-right font-mono text-red-500">4.1s</td>
                            <td class="px-4 py-2 text-right font-mono text-amber-600">2.8%</td>
                          </tr>
                          <tr>
                            <td class="px-4 py-2 font-mono text-gray-900">/dashboard</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">71k</td>
                            <td class="px-4 py-2 text-right font-mono text-amber-600">2.9s</td>
                            <td class="px-4 py-2 text-right font-mono text-emerald-600">0.5%</td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- How It Works Section -->
    <div class="relative bg-gray-50 py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <p class="text-sm font-medium text-indigo-600 uppercase tracking-wide mb-3">How It Works</p>
          <h2 class="text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl">
            Drop in the SDK. Watch real users.
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            Apps are recognized by their OTel <code class="text-sm bg-gray-100 px-1.5 py-0.5 rounded">service.name</code> and <code class="text-sm bg-gray-100 px-1.5 py-0.5 rounded">browser.*</code> attributes — no tag manager, no proprietary script.
          </p>
        </div>

        <div class="mx-auto max-w-5xl">
          <!-- Connecting line for desktop -->
          <div class="hidden lg:block relative">
            <div class="absolute top-8 left-[calc(12.5%+24px)] right-[calc(12.5%+24px)] h-px bg-indigo-200"></div>
          </div>

          <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Step 1 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-600 ring-2 ring-indigo-600">1</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Add the Web SDK</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Drop the OpenTelemetry browser SDK into your app, or the Swift/Android SDK into your mobile app.</p>
            </div>

            <!-- Step 2 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-600 ring-2 ring-indigo-600">2</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Point at OneUptime</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Set the OTLP exporter to your workspace and add your ingestion token. Page views and vitals stream in instantly.</p>
            </div>

            <!-- Step 3 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243l-1.59-1.59" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-600 ring-2 ring-indigo-600">3</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Auto-classified</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Apps with <code class="text-xs bg-gray-100 px-1 rounded">browser.*</code> or <code class="text-xs bg-gray-100 px-1 rounded">device.*</code> attributes are shown as RUM applications.</p>
            </div>

            <!-- Step 4 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-600 ring-2 ring-indigo-600">4</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Alert &amp; correlate</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Alert when LCP or error rate degrades, then jump to the backend trace behind a slow page.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Why OneUptime Section -->
    <div class="relative bg-white py-24 sm:py-32 overflow-hidden">

      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <!-- Section header -->
        <div class="mx-auto max-w-2xl text-center mb-20">
          <div class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-1.5 text-sm font-medium text-indigo-700 ring-1 ring-inset ring-indigo-600/20 mb-6">
            <svg class="h-4 w-4 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243l-1.59-1.59" />
            </svg>
            <span class="text-sm font-medium text-indigo-700">Why OneUptime for RUM</span>
          </div>
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl">
            Front-end experience, measured by real users
          </h2>
          <p class="mt-6 text-lg leading-8 text-gray-600">
            Synthetic checks tell you the app is up. RUM tells you how it actually feels — for every browser, device, and network your real users bring. And it links straight to the backend behind each session.
          </p>
        </div>

        <!-- Feature blocks -->
        <div class="space-y-24">

          <!-- Feature 1: Core Web Vitals -->
          <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
            <div class="relative">
              <div class="flex items-center gap-4 mb-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50 ring-1 ring-indigo-200">
                  <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                  </svg>
                </div>
                <span class="text-sm font-semibold text-indigo-600 uppercase tracking-wide">Core Web Vitals</span>
              </div>
              <h3 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">The metrics Google ranks you on</h3>
              <p class="mt-4 text-lg text-gray-600">Track LCP, INP, CLS, FCP, and TTFB at the 75th percentile, with good / needs-improvement / poor ratings — emitted straight from real browsers as OpenTelemetry metrics, broken down by page and device.</p>
              <ul class="mt-6 space-y-3">
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="h-5 w-5 text-indigo-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
