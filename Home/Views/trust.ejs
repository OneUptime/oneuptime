<!DOCTYPE html>
<html lang="en" id="trust">

<head>
  <title>OneUptime Trust Center | Security, Compliance & Privacy</title>
  <meta name="description" content="Security architecture, certifications, privacy, and operational practices behind OneUptime. SOC 2 Type II, ISO 27001, GDPR, HIPAA, and PCI compliant.">
  <%- include('head', {
    enableGoogleTagManager: typeof enableGoogleTagManager !== 'undefined' ? enableGoogleTagManager : false
}) -%>
  <style>
    /* Trust card glow */
    .trust-card-wrapper { position: relative; }
    .trust-card-wrapper::before {
      content: '';
      position: absolute;
      inset: -30px;
      border-radius: 50%;
      opacity: 0;
      transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      pointer-events: none;
      z-index: 0;
    }
    .trust-card-wrapper:hover::before { opacity: 1; }
    .trust-card {
      position: relative;
      z-index: 1;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .trust-card:hover { transform: translateY(-2px); }

    .trust-glow-emerald-wrapper::before { background: radial-gradient(ellipse at center, rgb(16 185 129 / 0.06) 0%, rgb(16 185 129 / 0.02) 40%, transparent 70%); }
    .trust-glow-emerald:hover { border-color: rgb(16 185 129 / 0.25); box-shadow: 0 0 0 1px rgb(16 185 129 / 0.08), 0 4px 16px -4px rgb(16 185 129 / 0.12); }
    .trust-glow-blue-wrapper::before { background: radial-gradient(ellipse at center, rgb(59 130 246 / 0.06) 0%, rgb(59 130 246 / 0.02) 40%, transparent 70%); }
    .trust-glow-blue:hover { border-color: rgb(59 130 246 / 0.25); box-shadow: 0 0 0 1px rgb(59 130 246 / 0.08), 0 4px 16px -4px rgb(59 130 246 / 0.12); }
    .trust-glow-violet-wrapper::before { background: radial-gradient(ellipse at center, rgb(139 92 246 / 0.06) 0%, rgb(139 92 246 / 0.02) 40%, transparent 70%); }
    .trust-glow-violet:hover { border-color: rgb(139 92 246 / 0.25); box-shadow: 0 0 0 1px rgb(139 92 246 / 0.08), 0 4px 16px -4px rgb(139 92 246 / 0.12); }
    .trust-glow-amber-wrapper::before { background: radial-gradient(ellipse at center, rgb(245 158 11 / 0.06) 0%, rgb(245 158 11 / 0.02) 40%, transparent 70%); }
    .trust-glow-amber:hover { border-color: rgb(245 158 11 / 0.25); box-shadow: 0 0 0 1px rgb(245 158 11 / 0.08), 0 4px 16px -4px rgb(245 158 11 / 0.12); }
    .trust-glow-rose-wrapper::before { background: radial-gradient(ellipse at center, rgb(244 63 94 / 0.06) 0%, rgb(244 63 94 / 0.02) 40%, transparent 70%); }
    .trust-glow-rose:hover { border-color: rgb(244 63 94 / 0.25); box-shadow: 0 0 0 1px rgb(244 63 94 / 0.08), 0 4px 16px -4px rgb(244 63 94 / 0.12); }
    .trust-glow-slate-wrapper::before { background: radial-gradient(ellipse at center, rgb(100 116 139 / 0.06) 0%, rgb(100 116 139 / 0.02) 40%, transparent 70%); }
    .trust-glow-slate:hover { border-color: rgb(100 116 139 / 0.25); box-shadow: 0 0 0 1px rgb(100 116 139 / 0.08), 0 4px 16px -4px rgb(100 116 139 / 0.12); }

    /* Status pulse */
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.7; transform: scale(0.92); }
    }
    .status-dot { animation: pulse-dot 2s ease-in-out infinite; }

    /* Anchor offset */
    section[id] { scroll-margin-top: 6rem; }
  </style>
</head>

<body class="bg-gray-50 antialiased text-gray-900">
  <%- include('nav') -%>

