<!DOCTYPE html>
<html lang="en" id="home">

<meta http-equiv="content-type" content="text/html;charset=utf-8" />

<head>
  <title>OneUptime | Topology - Service Map, Infrastructure & Network Maps</title>
  <meta name="description"
    content="Automatic topology maps built from your telemetry: a service map drawn from traces, a nested infrastructure map, and a live network map. See traffic, latency, and active incidents on every node. Open source.">
  <%- include('head', {
    enableGoogleTagManager: typeof enableGoogleTagManager !== 'undefined' ? enableGoogleTagManager : false
}) -%>
</head>

<body>
  <%- include('nav') -%>

  <main id="main-content">
    <!-- Hero Section -->
    <div class="relative isolate overflow-hidden bg-white" id="topo-hero-section">
      <!-- Subtle grid pattern background -->
      <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#f0f0f0_1px,transparent_1px),linear-gradient(to_bottom,#f0f0f0_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)]"></div>

      <!-- Grid glow effect that follows cursor - teal color -->
      <div id="topo-grid-glow" class="absolute inset-0 -z-9 pointer-events-none" style="opacity: 0; transition: opacity 0.3s ease-out; background: linear-gradient(to right, rgba(13, 148, 136, 0.3) 1px, transparent 1px), linear-gradient(to bottom, rgba(13, 148, 136, 0.3) 1px, transparent 1px); background-size: 4rem 4rem; -webkit-mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%); mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%);"></div>

      <div class="py-20 sm:py-28 lg:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-3xl text-center">
            <!-- Minimal badge -->
            <p class="text-sm font-medium text-teal-600 mb-4">Service, Infrastructure &amp; Network Topology</p>

            <h1 class="text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
              Your whole system, mapped automatically.
            </h1>
            <p class="mt-6 text-lg leading-8 text-gray-600 max-w-2xl mx-auto">
              OneUptime draws three living maps of your stack &mdash; the service call graph from your traces, the infrastructure that runs it, and the physical network underneath &mdash; without a single diagram to maintain. Traffic, latency, and active incidents are overlaid right on the map. Open source.
            </p>

            <div class="mt-10 flex items-center justify-center gap-x-6">
              <a href="/accounts/register"
                class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-800 transition-colors">
                Get started
              </a>
              <a href="/enterprise/demo" class="text-sm font-semibold text-gray-900 hover:text-gray-600 transition-colors">
                Request demo <span aria-hidden="true">&rarr;</span>
              </a>
            </div>

            <!-- Subtle feature list -->
            <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-gray-500">
              <span>Service Map</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Infrastructure</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Network</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Auto-discovered</span>
            </div>
          </div>

          <!-- Hero visual - Service map mockup -->
          <div class="mt-16 sm:mt-20">
            <div class="relative mx-auto max-w-5xl">
              <div class="rounded-xl bg-gray-900/5 p-1.5 ring-1 ring-gray-900/10">
                <!-- Topology Mockup -->
                <div class="rounded-lg bg-white shadow-lg overflow-hidden">
                  <!-- Header bar -->
                  <div class="bg-gray-50 px-6 py-3 flex items-center justify-between border-b border-gray-200">
                    <div class="flex items-center gap-3">
                      <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-red-400"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                        <div class="w-3 h-3 rounded-full bg-green-400"></div>
                      </div>
                      <div class="flex items-center gap-2">
                        <%- include('./Partials/icons/topology', {iconClass: 'h-4 w-4'}) %>
                        <span class="text-sm text-gray-700 font-semibold">Topology</span>
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <div class="flex items-center gap-1.5 px-2.5 py-1 bg-white rounded-md border border-gray-200 text-xs text-gray-500">
                        <svg class="h-3 w-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Past 1 day
                      </div>
                      <span class="hidden sm:flex items-center gap-1.5 px-2.5 py-1 bg-teal-50 rounded-md text-xs font-medium text-teal-700 border border-teal-200">
                        <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
                        auto-discovered
                      </span>
                    </div>
                  </div>

                  <!-- Tabs -->
                  <div class="px-6 pt-4">
                    <div class="flex items-center gap-2 text-xs">
                      <span class="px-3 py-1.5 rounded-md bg-teal-50 text-teal-700 font-semibold border border-teal-200">Service Map</span>
                      <span class="px-3 py-1.5 rounded-md text-gray-400 border border-transparent hover:text-gray-600">Infrastructure</span>
                      <span class="px-3 py-1.5 rounded-md text-gray-400 border border-transparent hover:text-gray-600">Network</span>
                    </div>
                  </div>

                  <!-- Map canvas -->
                  <div class="p-5">
                    <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-4 bg-[radial-gradient(#eef2f5_1px,transparent_1px)] bg-[size:18px_18px]">
                      <svg viewBox="0 0 760 320" class="w-full">
                        <!-- Edges -->
                        <line x1="380" y1="66" x2="180" y2="150" stroke="#99f6e4" stroke-width="3"/>
                        <line x1="380" y1="66" x2="580" y2="150" stroke="#99f6e4" stroke-width="3"/>
                        <line x1="180" y1="178" x2="180" y2="252" stroke="#99f6e4" stroke-width="2"/>
                        <line x1="580" y1="178" x2="580" y2="252" stroke="#fca5a5" stroke-width="3"/>
                        <line x1="380" y1="66" x2="380" y2="252" stroke="#99f6e4" stroke-width="2"/>
                        <!-- Edge labels -->
                        <text x="230" y="112" fill="#6b7280" font-size="11" font-family="monospace">1.4k/min &middot; 32ms</text>
                        <text x="452" y="112" fill="#dc2626" font-size="11" font-family="monospace">860/min &middot; 5.1% err</text>
                        <text x="592" y="220" fill="#dc2626" font-size="11" font-family="monospace">4.9% err</text>

                        <!-- api-gateway (top) -->
                        <rect x="312" y="42" width="136" height="34" rx="17" fill="#f0fdfa" stroke="#5eead4" stroke-width="1.5"/>
                        <circle cx="332" cy="59" r="4" fill="#10b981"/>
                        <text x="344" y="63" fill="#374151" font-size="12" font-family="monospace">api-gateway</text>

                        <!-- catalog-service (left) -->
                        <rect x="112" y="150" width="136" height="34" rx="17" fill="#f0fdfa" stroke="#5eead4" stroke-width="1.5"/>
                        <circle cx="132" cy="167" r="4" fill="#10b981"/>
                        <text x="144" y="171" fill="#374151" font-size="12" font-family="monospace">catalog-svc</text>

                        <!-- payments-service (right, incident) -->
                        <rect x="512" y="150" width="136" height="34" rx="17" fill="#fef2f2" stroke="#fca5a5" stroke-width="1.5"/>
                        <circle cx="532" cy="167" r="4" fill="#ef4444"/>
                        <text x="544" y="171" fill="#374151" font-size="12" font-family="monospace">payments-svc</text>
                        <circle cx="646" cy="150" r="10" fill="#ef4444"/>
                        <text x="646" y="154" fill="#ffffff" font-size="11" text-anchor="middle" font-weight="bold">1</text>

                        <!-- postgres (bottom-left) -->
                        <rect x="112" y="252" width="136" height="34" rx="17" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.5"/>
                        <circle cx="132" cy="269" r="4" fill="#10b981"/>
                        <text x="144" y="273" fill="#374151" font-size="12" font-family="monospace">postgres</text>

                        <!-- redis (bottom-center) -->
                        <rect x="312" y="252" width="136" height="34" rx="17" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.5"/>
                        <circle cx="332" cy="269" r="4" fill="#10b981"/>
                        <text x="344" y="273" fill="#374151" font-size="12" font-family="monospace">redis-cache</text>

                        <!-- stripe-gateway (bottom-right) -->
                        <rect x="512" y="252" width="136" height="34" rx="17" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.5"/>
                        <circle cx="532" cy="269" r="4" fill="#f59e0b"/>
                        <text x="544" y="273" fill="#374151" font-size="12" font-family="monospace">stripe-api</text>
                      </svg>
                      <div class="mt-2 flex items-center justify-center gap-5 text-[11px] text-gray-400">
                        <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-emerald-500"></span>Healthy</span>
                        <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-amber-500"></span>Degraded</span>
                        <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-red-500"></span>Active incident</span>
                        <span class="hidden sm:flex items-center gap-1.5"><span class="inline-block w-4 h-0.5 bg-teal-300"></span>edge width = traffic</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('logo-roll') -%>

    <!-- How It Works Section -->
    <div class="relative bg-gray-50 py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <p class="text-sm font-medium text-teal-600 uppercase tracking-wide mb-3">How It Works</p>
          <h2 class="text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl">
            No diagram to draw. No diagram to maintain.
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            The maps build themselves from the telemetry you already send. Ship data, and the graph appears &mdash; then keeps itself current as your architecture changes.
          </p>
        </div>

        <div class="mx-auto max-w-5xl">
          <!-- Connecting line for desktop -->
          <div class="hidden lg:block relative">
            <div class="absolute top-8 left-[calc(12.5%+24px)] right-[calc(12.5%+24px)] h-px bg-teal-200"></div>
          </div>

          <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Step 1 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-teal-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-teal-600 ring-2 ring-teal-600">1</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Send your telemetry</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Point your existing OpenTelemetry traces at OneUptime and connect your infrastructure &mdash; Kubernetes, Proxmox, Docker Swarm, hosts, or SNMP network devices.</p>
            </div>

            <!-- Step 2 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-teal-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-teal-600 ring-2 ring-teal-600">2</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Entities &amp; links discovered</h3>
              <p class="text-sm text-gray-600 leading-relaxed">OneUptime derives an entity registry from your data &mdash; every service, pod, host, and device &mdash; and the relationships between them: who calls whom, what runs on what.</p>
            </div>

            <!-- Step 3 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-teal-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-teal-600 ring-2 ring-teal-600">3</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Three maps drawn for you</h3>
              <p class="text-sm text-gray-600 leading-relaxed">The same registry powers three purpose-built views: the layer-7 Service Map, the nested Infrastructure map, and the live Network map &mdash; one click apart.</p>
            </div>

            <!-- Step 4 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-teal-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-teal-600 ring-2 ring-teal-600">4</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Incidents on the map</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Active incidents and alerts light up the services that own them, and every node and edge drills down to the traffic, latency, and detail behind it.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Why OneUptime Section -->
    <div class="relative bg-white py-24 sm:py-32 overflow-hidden">

      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <!-- Section header -->
        <div class="mx-auto max-w-2xl text-center mb-20">
          <div class="inline-flex items-center gap-2 rounded-full bg-teal-50 px-4 py-1.5 text-sm font-medium text-teal-700 ring-1 ring-inset ring-teal-600/20 mb-6">
            <svg class="h-4 w-4 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
            <span class="text-sm font-medium text-teal-700">Why OneUptime for topology</span>
          </div>
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl">
            One picture beats a wall of dashboards
          </h2>
          <p class="mt-6 text-lg leading-8 text-gray-600">
            A hand-drawn architecture diagram is out of date the day after you draw it. These maps are generated from the same telemetry that powers your logs, metrics, and traces &mdash; so they are always current, and every node is a doorway into the data behind it.
          </p>
        </div>

        <!-- Feature blocks -->
        <div class="space-y-24">

          <!-- Feature 1: Service Map -->
          <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
            <div class="relative">
              <div class="flex items-center gap-4 mb-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-teal-50 ring-1 ring-teal-200">
                  <svg class="h-5 w-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" />
                  </svg>
                </div>
                <span class="text-sm font-semibold text-teal-600 uppercase tracking-wide">Service Map</span>
              </div>
              <h3 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Your call graph, drawn from your traces</h3>
              <p class="mt-4 text-lg text-gray-600">Services become nodes and real request paths become edges, each carrying live call rate, error rate, and average latency over the window you pick. Edge thickness scales with traffic, so the hot paths are obvious at a glance. Click an edge for its call history; click a node for its detail drawer &mdash; without ever leaving the map.</p>
              <ul class="mt-6 space-y-3">
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="h-5 w-5 text-teal-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Auto-generated from spans &mdash; nothing to draw
                </li>
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="h-5 w-5 text-teal-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Call rate, error rate &amp; latency on every edge
                </li>
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="h-5 w-5 text-teal-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Health colors by error rate: healthy, degraded, critical
                </li>
              </ul>
              <a href="/accounts/register" class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800 transition-colors mt-8">
                Get started
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>
            </div>
            <div class="mt-12 lg:mt-0">
              <div class="relative">
                <div class="absolute -inset-4 bg-gray-100/50 rounded-3xl blur-2xl"></div>

                <!-- Edge drill-down Mockup -->
                <div class="relative bg-white rounded-xl shadow-lg overflow-hidden max-w-md mx-auto border border-gray-200">
                  <div class="bg-gray-50 px-4 py-2.5 flex items-center gap-3 border-b border-gray-100">
                    <div class="flex gap-1.5">
                      <div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div>
                      <div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div>
                      <div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div>
                    </div>
                    <div class="flex-1 text-center">
                      <span class="text-xs text-gray-400">Edge &middot; api-gateway &rarr; payments-svc</span>
                    </div>
                  </div>
                  <div class="p-4 space-y-3">
                    <div class="grid grid-cols-3 gap-2">
                      <div class="bg-gray-50 rounded-lg p-2.5 border border-gray-200">
                        <div class="text-[9px] font-medium text-gray-400 uppercase tracking-wider mb-1">Calls</div>
                        <div class="text-sm font-bold text-gray-900">860<span class="text-[9px] font-medium text-gray-400 ml-0.5">/min</span></div>
                      </div>
                      <div class="bg-red-50 rounded-lg p-2.5 border border-red-200">
                        <div class="text-[9px] font-medium text-red-400 uppercase tracking-wider mb-1">Errors</div>
                        <div class="text-sm font-bold text-red-600">5.1%</div>
                      </div>
                      <div class="bg-gray-50 rounded-lg p-2.5 border border-gray-200">
                        <div class="text-[9px] font-medium text-gray-400 uppercase tracking-wider mb-1">Avg</div>
                        <div class="text-sm font-bold text-gray-900">418<span class="text-[9px] font-medium text-gray-400 ml-0.5">ms</span></div>
                      </div>
                    </div>
                    <div class="bg-gray-50 rounded-lg p-3 border border-gray-200">
                      <div class="flex items-center justify-between mb-2">
                        <span class="text-[10px] font-semibold text-gray-600">Calls &amp; errors over time</span>
                        <span class="text-[9px] text-red-500 font-semibold">error spike</span>
                      </div>
                      <svg viewBox="0 0 400 70" class="w-full h-14">
                        <path d="M0,40 L50,42 L100,38 L150,41 L200,39 L250,42 L300,40 L350,43 L400,41" fill="none" stroke="#14b8a6" stroke-width="2" stroke-linecap="round"/>
                        <path d="M0,64 L50,63 L100,64 L150,62 L200,63 L250,60 L300,44 L350,28 L400,20" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/>
                      </svg>
                      <div class="flex items-center gap-3 text-[9px] text-gray-400">
                        <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-teal-500 inline-block"></span>calls/min</span>
                        <span class="flex items-center gap-1"><span class="w-3 h-0.5 bg-red-500 inline-block"></span>errors/min</span>
