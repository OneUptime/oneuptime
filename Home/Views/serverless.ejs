                              <span class="text-[10px] text-gray-500">Invocations</span>
                            </div>
                            <div class="flex items-center gap-1">
                              <span class="w-2 h-2 rounded-full bg-indigo-500"></span>
                              <span class="text-[10px] text-gray-500">p95</span>
                            </div>
                          </div>
                        </div>
                        <svg viewBox="0 0 400 100" class="w-full h-24">
                          <defs>
                            <linearGradient id="fnInvGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                              <stop offset="0%" style="stop-color:#d946ef;stop-opacity:0.2"/>
                              <stop offset="100%" style="stop-color:#d946ef;stop-opacity:0"/>
                            </linearGradient>
                          </defs>
                          <line x1="0" y1="25" x2="400" y2="25" stroke="#f3f4f6" stroke-width="1"/>
                          <line x1="0" y1="50" x2="400" y2="50" stroke="#f3f4f6" stroke-width="1"/>
                          <line x1="0" y1="75" x2="400" y2="75" stroke="#f3f4f6" stroke-width="1"/>
                          <path d="M0,70 L25,66 L50,60 L75,64 L100,52 L125,55 L150,44 L175,48 L200,38 L225,42 L250,34 L275,40 L300,30 L325,36 L350,28 L375,33 L400,26 L400,100 L0,100 Z" fill="url(#fnInvGrad)"/>
                          <path d="M0,70 L25,66 L50,60 L75,64 L100,52 L125,55 L150,44 L175,48 L200,38 L225,42 L250,34 L275,40 L300,30 L325,36 L350,28 L375,33 L400,26" fill="none" stroke="#d946ef" stroke-width="2" stroke-linecap="round"/>
                          <path d="M0,58 L25,60 L50,54 L75,57 L100,50 L125,53 L150,48 L175,52 L200,45 L225,49 L250,43 L275,47 L300,42 L325,46 L350,41 L375,45 L400,40" fill="none" stroke="#6366f1" stroke-width="2" stroke-dasharray="3 3" stroke-linecap="round"/>
                        </svg>
                      </div>

                      <!-- Cold start panel -->
                      <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-4">
                        <div class="text-sm font-semibold text-gray-800 mb-1">Cold Starts</div>
                        <div class="text-[10px] text-gray-400 mb-4">Init duration by function</div>
                        <div class="space-y-3">
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">image-resize</span>
                              <span class="text-[10px] text-gray-500">680ms</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-amber-400 h-1.5 rounded-full" style="width:82%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">checkout</span>
                              <span class="text-[10px] text-gray-500">240ms</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-emerald-400 h-1.5 rounded-full" style="width:29%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">auth-verify</span>
                              <span class="text-[10px] text-gray-500">120ms</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-emerald-400 h-1.5 rounded-full" style="width:15%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">pdf-export</span>
                              <span class="text-[10px] text-gray-500">910ms</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-red-400 h-1.5 rounded-full" style="width:96%"></div></div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Functions table -->
                    <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                      <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                        <span class="text-xs font-semibold text-gray-700">Functions by invocations</span>
                        <span class="text-[10px] text-gray-400">34 total</span>
                      </div>
                      <table class="w-full text-xs">
                        <thead class="bg-white border-b border-gray-100">
                          <tr>
                            <th class="px-4 py-2 text-left text-[10px] font-semibold uppercase tracking-wider text-gray-500">Function</th>
                            <th class="px-4 py-2 text-left text-[10px] font-semibold uppercase tracking-wider text-gray-500">Runtime</th>
                            <th class="px-4 py-2 text-right text-[10px] font-semibold uppercase tracking-wider text-gray-500">Invocations</th>
                            <th class="px-4 py-2 text-right text-[10px] font-semibold uppercase tracking-wider text-gray-500">p95</th>
                            <th class="px-4 py-2 text-right text-[10px] font-semibold uppercase tracking-wider text-gray-500">Errors</th>
                          </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                          <tr>
                            <td class="px-4 py-2 font-mono text-gray-900">checkout-handler</td>
                            <td class="px-4 py-2 text-gray-500">nodejs20.x</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">42,180</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">208ms</td>
                            <td class="px-4 py-2 text-right font-mono text-emerald-600">0.1%</td>
                          </tr>
                          <tr>
                            <td class="px-4 py-2 font-mono text-gray-900">image-resize</td>
                            <td class="px-4 py-2 text-gray-500">python3.12</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">31,902</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">512ms</td>
                            <td class="px-4 py-2 text-right font-mono text-amber-600">1.2%</td>
                          </tr>
                          <tr>
                            <td class="px-4 py-2 font-mono text-gray-900">auth-verify</td>
                            <td class="px-4 py-2 text-gray-500">go1.x</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">28,455</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">46ms</td>
                            <td class="px-4 py-2 text-right font-mono text-emerald-600">0.0%</td>
                          </tr>
                          <tr>
                            <td class="px-4 py-2 font-mono text-gray-900">pdf-export</td>
                            <td class="px-4 py-2 text-gray-500">nodejs20.x</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">9,612</td>
                            <td class="px-4 py-2 text-right font-mono text-gray-900">1.4s</td>
                            <td class="px-4 py-2 text-right font-mono text-red-500">3.8%</td>
                          </tr>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- How It Works Section -->
    <div class="relative bg-gray-50 py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <p class="text-sm font-medium text-fuchsia-600 uppercase tracking-wide mb-3">How It Works</p>
          <h2 class="text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl">
            Instrument once. Every function, monitored.
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            Auto-discovery is keyed on the OTel <code class="text-sm bg-gray-100 px-1.5 py-0.5 rounded">faas.name</code> resource attribute — no proprietary agent, no manual registration.
          </p>
        </div>

        <div class="mx-auto max-w-5xl">
          <!-- Connecting line for desktop -->
          <div class="hidden lg:block relative">
            <div class="absolute top-8 left-[calc(12.5%+24px)] right-[calc(12.5%+24px)] h-px bg-fuchsia-200"></div>
          </div>

          <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Step 1 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-fuchsia-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-fuchsia-600 ring-2 ring-fuchsia-600">1</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Add the OTel layer</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Attach the OpenTelemetry Lambda Layer or drop the OTel SDK into your function. No code change required on AWS.</p>
            </div>

            <!-- Step 2 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-fuchsia-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-fuchsia-600 ring-2 ring-fuchsia-600">2</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Point at OneUptime</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Set <code class="text-xs bg-gray-100 px-1 rounded">OTEL_EXPORTER_OTLP_ENDPOINT</code> to your workspace and add your ingestion token.</p>
            </div>

            <!-- Step 3 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-fuchsia-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-fuchsia-600 ring-2 ring-fuchsia-600">3</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Auto-discovered</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Functions appear on the first invocation, with cloud platform, region, and runtime captured automatically.</p>
            </div>

            <!-- Step 4 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-fuchsia-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-fuchsia-600 ring-2 ring-fuchsia-600">4</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Alert on what matters</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Set thresholds for error rate, p95 duration, cold-start frequency, and invocation drop-offs.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Why OneUptime Section -->
    <div class="relative bg-white py-24 sm:py-32 overflow-hidden">

      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <!-- Section header -->
        <div class="mx-auto max-w-2xl text-center mb-20">
          <div class="inline-flex items-center gap-2 rounded-full bg-fuchsia-50 px-4 py-1.5 text-sm font-medium text-fuchsia-700 ring-1 ring-inset ring-fuchsia-600/20 mb-6">
            <svg class="h-4 w-4 text-fuchsia-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            <span class="text-sm font-medium text-fuchsia-700">Why OneUptime for Serverless</span>
          </div>
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl">
            Serverless observability without the lock-in
          </h2>
          <p class="mt-6 text-lg leading-8 text-gray-600">
            From a single Lambda to thousands of functions across clouds, OneUptime captures the full picture — invocations, latency, cold starts, errors, and the distributed trace behind every call.
          </p>
        </div>

        <!-- Feature blocks -->
        <div class="space-y-24">

          <!-- Feature 1: Auto-discovery -->
          <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
            <div class="relative">
              <div class="flex items-center gap-4 mb-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-fuchsia-50 ring-1 ring-fuchsia-200">
                  <svg class="h-5 w-5 text-fuchsia-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                  </svg>
                </div>
                <span class="text-sm font-semibold text-fuchsia-600 uppercase tracking-wide">Auto-Discovery</span>
              </div>
              <h3 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Functions appear the moment they invoke</h3>
              <p class="mt-4 text-lg text-gray-600">No manifests, no manual registration, no separate agent. Emit any OTel span or metric with a <code class="text-sm bg-gray-100 px-1.5 py-0.5 rounded">faas.name</code> attribute and the function shows up automatically.</p>
              <ul class="mt-6 space-y-3">
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="h-5 w-5 text-fuchsia-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Keyed on the OTel <code class="text-xs">faas.name</code> resource attribute
                </li>
