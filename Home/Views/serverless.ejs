                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">Functions</div>
                        <div class="text-xl font-bold text-gray-900">34</div>
                        <div class="text-[10px] text-gray-500 font-medium mt-1">active</div>
                      </div>
                    </div>

                    <!-- Charts row -->
                    <div class="grid grid-cols-3 gap-3 mb-5">
