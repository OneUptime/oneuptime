                          <div class="bg-emerald-400 h-1.5 rounded-full" style="width: 4%"></div>
                        </div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">p95 Duration</div>
                        <div class="text-xl font-bold text-gray-900">312ms</div>
                        <div class="text-[10px] text-gray-500 font-medium mt-1">p50 84ms</div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mb-2">Cold starts</div>
                        <div class="text-xl font-bold text-gray-900">2.1%</div>
