  <style>
    @keyframes fadeSlideIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>

  <!-- Grid glow cursor effect -->
  <script>
    (function() {
      const heroSection = document.getElementById('serverless-hero-section');
      const gridGlow = document.getElementById('serverless-grid-glow');

      if (heroSection && gridGlow) {
        heroSection.addEventListener('mousemove', (e) => {
          const rect = heroSection.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          gridGlow.style.setProperty('--mouse-x', x + 'px');
          gridGlow.style.setProperty('--mouse-y', y + 'px');
          gridGlow.style.opacity = '1';
        });

        heroSection.addEventListener('mouseleave', () => {
          gridGlow.style.opacity = '0';
        });
      }
    })();
  </script>
