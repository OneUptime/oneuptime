          <a href="/product/status-page" class="group inline-flex items-center gap-1 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">
            Explore Status Pages
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5" /></svg>
          </a>
        </div>
      </div>

      <!-- Visual -->
      <div class="lg:col-span-3">
        <div class="relative">
          <div class="absolute -inset-8 rounded-full pointer-events-none" style="background: radial-gradient(ellipse at center, rgb(16 185 129 / 0.06) 0%, rgb(16 185 129 / 0.02) 40%, transparent 70%);" aria-hidden="true"></div>
          <div class="relative">
            <%- include('./home-mocks/mock-communicate') -%>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
