              <span class="relative flex h-8 w-8 items-center justify-center rounded-full bg-rose-50 ring-1 ring-inset ring-rose-200">
                <svg class="h-4 w-4 text-rose-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              </span>
              <div>
                <p class="text-xs font-semibold text-gray-900">Calling on-call engineer&hellip;</p>
                <p class="mt-0.5 text-xs text-gray-500">No answer? Escalates to backup.</p>
              </div>
            </div>
          </div>

          <!-- Floating: Slack command card -->
          <div class="absolute -bottom-6 -left-4 hidden lg:block rounded-xl bg-white shadow-lg ring-1 ring-gray-200 p-4" aria-hidden="true">
            <p class="font-mono text-xs text-gray-900">/incident declare &ldquo;Checkout API degraded&rdquo;</p>
            <p class="mt-1 text-xs text-gray-500">#ops &middot; declared from Slack</p>
          </div>
        </div>
      </div>

