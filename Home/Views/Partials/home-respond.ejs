            <img src="/img/incidents.png" alt="OneUptime incident timeline showing automatic escalation and status updates" class="w-full rounded-lg shadow-sm ring-1 ring-gray-900/10" loading="lazy" decoding="async" />
          </div>

          <!-- Floating: phone call card -->
          <div class="absolute -top-6 -right-4 hidden lg:block rounded-xl bg-white shadow-lg ring-1 ring-gray-200 p-4 max-w-[15rem]" aria-hidden="true">
