<section id="diagnose" class="relative bg-white py-24 lg:py-32 overflow-hidden scroll-mt-24" aria-labelledby="diagnose-title">
  <div class="absolute inset-0 bg-gradient-to-b from-gray-50/50 to-white" aria-hidden="true"></div>
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-amber-200/70 to-transparent" aria-hidden="true"></div>
  <div class="absolute -top-24 left-1/2 -translate-x-1/2 h-72 w-72 rounded-full bg-amber-100/50 blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="pointer-events-none select-none absolute -top-6 left-8 hidden lg:block font-mono text-[10rem] leading-none font-semibold tracking-tighter text-amber-600/[0.05]" aria-hidden="true">2:54 AM</div>

  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Header -->
    <div data-reveal class="mx-auto max-w-2xl text-center mb-12">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="inline-flex items-center rounded-full bg-amber-50 px-2.5 py-1 font-mono text-xs text-amber-600 ring-1 ring-inset ring-amber-200 tabular-nums">2:54 AM</span>
        <p class="text-sm font-medium text-amber-600 tracking-wide uppercase">Diagnose</p>
      </div>
      <h2 id="diagnose-title" class="text-4xl sm:text-5xl font-semibold tracking-tight text-gray-900">
        Root cause in minutes, not war rooms.
      </h2>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed">
        Follow one slow request from frontend to database. Jump from the error to the trace to the exact log line. It's all one platform, so the answer to &ldquo;why?&rdquo; is a click away - not a correlation exercise across four vendor tabs.
      </p>
    </div>

    <!-- Trace waterfall: the root cause, found -->
    <div data-reveal data-reveal-delay="150" class="relative mx-auto max-w-4xl mb-12">
      <div class="absolute -inset-8 rounded-full pointer-events-none" style="background: radial-gradient(ellipse at center, rgb(245 158 11 / 0.06) 0%, rgb(245 158 11 / 0.02) 40%, transparent 70%);" aria-hidden="true"></div>
      <div class="relative tilt-c">
        <%- include('./home-mocks/mock-diagnose') -%>
      </div>
    </div>

    <!-- Linked signal cards -->
    <div class="relative mx-auto max-w-6xl">
      <div class="relative grid grid-cols-1 gap-4 md:grid-cols-3">
        <a data-reveal href="/product/traces" class="group relative z-10 rounded-2xl bg-white border border-gray-200 shadow-sm p-6 transition-all hover:-translate-y-0.5 hover:shadow-[0_12px_40px_-12px_rgba(0,0,0,0.1)]">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-yellow-50 to-yellow-100 ring-1 ring-inset ring-yellow-200 mb-4">
            <svg class="h-5 w-5 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>
          </span>
          <h3 class="text-base font-semibold text-gray-900 mb-1">Traces</h3>
          <p class="text-sm text-gray-500 leading-relaxed">See every hop from frontend to database and pinpoint the slow service in seconds. Compare before and after a deploy.</p>
        </a>

        <a data-reveal data-reveal-delay="75" href="/product/logs-management" class="group relative z-10 rounded-2xl bg-white border border-gray-200 shadow-sm p-6 transition-all hover:-translate-y-0.5 hover:shadow-[0_12px_40px_-12px_rgba(0,0,0,0.1)]">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-amber-50 to-amber-100 ring-1 ring-inset ring-amber-200 mb-4">
            <svg class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12" /></svg>
          </span>
          <h3 class="text-base font-semibold text-gray-900 mb-1">Logs</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Search fast, tail in real time, alert when error patterns spike. Jump from any log line to the trace it belongs to.</p>
        </a>

        <a data-reveal data-reveal-delay="150" href="/product/exceptions" class="group relative z-10 rounded-2xl bg-white border border-gray-200 shadow-sm p-6 transition-all hover:-translate-y-0.5 hover:shadow-[0_12px_40px_-12px_rgba(0,0,0,0.1)]">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-orange-50 to-orange-100 ring-1 ring-inset ring-orange-200 mb-4">
            <svg class="h-5 w-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" /></svg>
          </span>
          <h3 class="text-base font-semibold text-gray-900 mb-1">Errors &amp; Exceptions</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Stack traces grouped so one bug isn't 214 alerts - and you see exactly which deploy introduced it.</p>
        </a>
      </div>

      <!-- OpenTelemetry strip -->
      <div data-reveal data-reveal-delay="225" class="mt-6 rounded-2xl border border-gray-200 bg-gray-50 p-6 sm:flex sm:items-center sm:justify-between sm:gap-6">
        <div class="flex items-start gap-4">
          <span class="mt-0.5 inline-flex h-10 w-10 flex-none items-center justify-center rounded-lg bg-gray-700">
            <svg class="h-5 w-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.6974 13.1173c-1.0224 1.0224-1.0224 2.68 0 3.7024 1.0224 1.0224 2.68 1.0224 3.7024 0 1.0224-1.0223 1.0224-2.68 0-3.7024-1.0223-1.0223-2.68-1.0223-3.7024 0zm2.7677 2.7701c-.5063.5063-1.3267.5063-1.833 0s-.5063-1.3266 0-1.833c.5063-.5062 1.3267-.5062 1.833 0 .5063.504.5063 1.3267 0 1.833zM16.356.2355l-1.6041 1.6042c-.314.314-.314.83 0 1.144L21.015 9.247c.314.314.83.314 1.144 0l1.6042-1.6041c.314-.314.314-.83 0-1.144L17.4976.2354c-.314-.314-.8276-.314-1.1416 0zM5.1173 20.734c.2848-.2848.2848-.7497 0-1.0345l-.8155-.8155c-.2848-.2848-.7497-.2848-1.0345 0l-1.6845 1.6845-.0024.0024-.4625-.4625c-.2556-.2556-.6718-.2556-.925 0-.2556.2556-.2556.6718 0 .925l2.775 2.775c.2556.2556.6718.2556.925 0 .2532-.2556.2556-.6718 0-.925l-.4625-.4625.0024-.0024zm8.4856-15.893-3.5637 3.5637c-.3164.3164-.3164.8374 0 1.1538l2.2006 2.2005c1.5554-1.1197 3.7365-.981 5.1361.4187l1.7819-1.7818c.3164-.3165.3164-.8374 0-1.1538l-4.401-4.401c-.3165-.319-.8374-.319-1.1539 0zm-2.2881 7.8455-1.2999-1.2999c-.3043-.3043-.8033-.3043-1.1076 0l-4.5836 4.586c-.3042.3043-.3042.8033 0 1.1076l2.5973 2.5973c.3043.3043.8033.3043 1.1076 0l2.9478-2.9527c-.6231-1.2877-.5112-2.8431.3384-4.0383z"/></svg>
          </span>
          <div>
            <h3 class="text-base font-semibold text-gray-900">OpenTelemetry-native</h3>
            <p class="mt-1 text-sm text-gray-500 leading-relaxed">Instrument once with the open standard. Your telemetry stays portable - you're never locked into a proprietary agent.</p>
          </div>
        </div>
        <div class="mt-4 sm:mt-0 flex flex-wrap gap-2 flex-none">
          <a href="/product/metrics" class="px-3 py-1.5 text-xs font-medium text-gray-600 bg-white rounded-md border border-gray-200 hover:bg-gray-100 hover:text-gray-900 transition-colors">Metrics</a>
          <a href="/product/profiles" class="px-3 py-1.5 text-xs font-medium text-gray-600 bg-white rounded-md border border-gray-200 hover:bg-gray-100 hover:text-gray-900 transition-colors">Profiling</a>
          <a href="/product/ai-observability" class="px-3 py-1.5 text-xs font-medium text-gray-600 bg-white rounded-md border border-gray-200 hover:bg-gray-100 hover:text-gray-900 transition-colors">AI &amp; LLM</a>
          <a href="/product/rum" class="px-3 py-1.5 text-xs font-medium text-gray-600 bg-white rounded-md border border-gray-200 hover:bg-gray-100 hover:text-gray-900 transition-colors">Real User Monitoring</a>
        </div>
      </div>

      <!-- CTA -->
      <div data-reveal data-reveal-delay="300" class="mt-10 text-center">
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="/accounts/register" class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-6 py-2.5 text-sm font-medium text-white shadow-sm transition-all hover:bg-gray-700">
            Send your first traces
          </a>
          <a href="/product/observability" class="group inline-flex items-center gap-1 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">
            Explore Observability
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5" /></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
