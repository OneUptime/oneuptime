          <span class="text-xs font-medium text-emerald-700">with OneUptime</span>
        </div>
        <ul class="space-y-4">
          <li class="flex gap-3">
            <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-emerald-100">
