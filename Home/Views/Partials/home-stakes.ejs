<section class="relative bg-white py-24 lg:py-32 overflow-hidden" aria-labelledby="stakes-title">
  <div class="absolute inset-0 bg-gradient-to-b from-gray-50/50 to-white" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center mb-16">
      <h2 id="stakes-title" class="text-4xl sm:text-5xl font-semibold tracking-tight text-gray-900">
        There are two kinds of 3&nbsp;a.m.
      </h2>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed">
        The one where an angry customer tells you you're down &mdash; and the one where the fix is already in review. The difference is what's watching while you sleep.
      </p>
    </div>

    <!-- Contrast cards -->
    <div class="mx-auto grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-2">
      <!-- Without -->
      <div class="relative overflow-hidden rounded-2xl bg-white border border-gray-200 shadow-sm p-8">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-rose-400/70 via-rose-300/40 to-transparent" aria-hidden="true"></div>
        <div class="absolute -top-16 -right-16 h-40 w-40 rounded-full bg-rose-100/40 blur-2xl pointer-events-none" aria-hidden="true"></div>
        <div class="relative inline-flex items-center gap-2 rounded-full bg-rose-50 px-3 py-1 ring-1 ring-inset ring-rose-200 mb-6">
          <span class="font-mono text-xs text-rose-600 tabular-nums">03:00</span>
          <span class="text-xs font-medium text-rose-700">without OneUptime</span>
        </div>
        <ul class="space-y-4">
          <li class="flex gap-3">
            <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-rose-100">
              <svg class="h-3 w-3 text-rose-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </span>
            <span class="text-sm text-gray-600 leading-relaxed">A customer tweet is your alerting system</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-rose-100">
              <svg class="h-3 w-3 text-rose-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </span>
            <span class="text-sm text-gray-600 leading-relaxed">The wrong engineer gets woken up &mdash; and wakes three more to find the right one</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-rose-100">
              <svg class="h-3 w-3 text-rose-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </span>
            <span class="text-sm text-gray-600 leading-relaxed">A war-room Slack scroll: &ldquo;wait, who's on this?&rdquo;</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-rose-100">
              <svg class="h-3 w-3 text-rose-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </span>
            <span class="text-sm text-gray-600 leading-relaxed">Support inbox floods while you're still guessing at the cause across four dashboards</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full bg-rose-100">
              <svg class="h-3 w-3 text-rose-600" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </span>
            <span class="text-sm text-gray-600 leading-relaxed">The postmortem doc stays blank for a week</span>
          </li>
        </ul>
      </div>

