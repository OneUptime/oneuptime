                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 class="mt-6 text-xl font-semibold text-gray-900">Full API access</h3>
              <p class="mt-4 text-gray-600 leading-relaxed">Build, run, and inspect runbooks programmatically. CRUD endpoints, execution queries, and webhook-friendly responses.</p>
            </div>
          </div>

          <!-- Card 6: Open source -->
          <div class="group relative">
            <div class="relative h-full rounded-2xl border border-gray-200 bg-white p-8 transition-all duration-300 hover:border-emerald-200 hover:shadow-lg">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-50 ring-1 ring-emerald-200">
