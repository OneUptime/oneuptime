                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="flex items-center justify-between mb-2">
                          <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider">Devices</div>
                          <div class="w-6 h-6 rounded-md bg-sky-50 flex items-center justify-center">
                            <%- include('./Partials/icons/network-devices', {iconClass: 'w-3.5 h-3.5'}) %>
                          </div>
                        </div>
                        <div class="text-xl font-bold text-gray-900">48</div>
                        <div class="flex items-center gap-1 mt-1">
                          <span class="w-1 h-1 rounded-full bg-emerald-500"></span>
                          <span class="text-[10px] text-emerald-600 font-medium">switches, routers &amp; firewalls</span>
                        </div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="flex items-center justify-between mb-2">
                          <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider">Reachable</div>
                          <div class="w-6 h-6 rounded-md bg-emerald-50 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                          </div>
                        </div>
                        <div class="text-xl font-bold text-gray-900">47</div>
                        <div class="flex items-center gap-1.5 mt-1">
                          <span class="text-[10px] text-emerald-600 font-medium">97.9% up</span>
                          <span class="text-[10px] text-gray-400">1 unreachable</span>
                        </div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="flex items-center justify-between mb-2">
                          <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider">Interfaces Up</div>
                          <div class="w-6 h-6 rounded-md bg-sky-50 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5L7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5" />
                            </svg>
                          </div>
                        </div>
                        <div class="text-xl font-bold text-gray-900">1,872</div>
                        <div class="flex items-center gap-1 mt-1">
                          <span class="w-1 h-1 rounded-full bg-amber-500"></span>
                          <span class="text-[10px] text-amber-600 font-medium">3 down on monitored ports</span>
                        </div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
