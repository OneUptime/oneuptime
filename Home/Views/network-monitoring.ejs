                          <!-- Out fill -->
                          <path d="M0,72 L25,70 L50,74 L75,66 L100,70 L125,64 L150,68 L175,60 L200,66 L225,62 L250,68 L275,58 L300,66 L325,62 L350,58 L375,64 L400,60 L400,100 L0,100 Z" fill="url(#netOutGrad)"/>
                          <!-- Out line -->
                          <path d="M0,72 L25,70 L50,74 L75,66 L100,70 L125,64 L150,68 L175,60 L200,66 L225,62 L250,68 L275,58 L300,66 L325,62 L350,58 L375,64 L400,60" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round"/>
                          <!-- Y-axis labels -->
                          <text x="2" y="23" fill="#9ca3af" font-size="8">1 Gbps</text>
                          <text x="2" y="48" fill="#9ca3af" font-size="8">750 M</text>
                          <text x="2" y="73" fill="#9ca3af" font-size="8">500 M</text>
                        </svg>
                      </div>

                      <!-- Utilization breakdown -->
                      <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-4">
                        <div class="text-sm font-semibold text-gray-800 mb-1">Busiest Ports</div>
                        <div class="text-[10px] text-gray-400 mb-4">Utilization percent, monitored interfaces</div>
                        <div class="space-y-3">
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">core-sw-01 Gi1/0/48</span>
                              <span class="text-[11px] font-semibold text-red-600">91%</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-red-400 h-1.5 rounded-full" style="width:91%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">edge-rtr-01 ether1</span>
                              <span class="text-[11px] font-semibold text-amber-600">78%</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-amber-400 h-1.5 rounded-full" style="width:78%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">dist-sw-03 Gi1/0/1</span>
                              <span class="text-[11px] font-semibold text-gray-700">54%</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-sky-400 h-1.5 rounded-full" style="width:54%"></div></div>
                          </div>
                          <div>
                            <div class="flex items-center justify-between mb-1">
                              <span class="text-[11px] font-mono text-gray-600">fw-hq-01 wan0</span>
                              <span class="text-[11px] font-semibold text-gray-700">37%</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-1.5"><div class="bg-sky-400 h-1.5 rounded-full" style="width:37%"></div></div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Devices & needs-attention row -->
                    <div class="grid grid-cols-2 gap-3">
                      <!-- Devices -->
                      <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                        <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                          <span class="text-xs font-semibold text-gray-700">Devices</span>
                          <span class="text-[10px] text-gray-400">48 total</span>
                        </div>
                        <div class="divide-y divide-gray-100">
                          <div class="px-4 py-2 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                              <span class="text-xs font-mono text-gray-700">core-sw-01</span>
                            </div>
                            <div class="flex items-center gap-2">
                              <span class="text-[10px] text-gray-400">Cisco IOS-XE</span>
                              <span class="text-[10px] text-emerald-600 font-medium">52/52 up</span>
                            </div>
                          </div>
                          <div class="px-4 py-2 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                              <span class="text-xs font-mono text-gray-700">edge-rtr-01</span>
                            </div>
                            <div class="flex items-center gap-2">
                              <span class="text-[10px] text-gray-400">MikroTik RouterOS</span>
                              <span class="text-[10px] text-emerald-600 font-medium">10/10 up</span>
                            </div>
                          </div>
                          <div class="px-4 py-2 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                              <span class="text-xs font-mono text-gray-700">dist-sw-03</span>
                            </div>
                            <div class="flex items-center gap-2">
                              <span class="text-[10px] text-gray-400">Ubiquiti EdgeOS</span>
                              <span class="text-[10px] text-amber-600 font-medium">23/24 up</span>
                            </div>
                          </div>
