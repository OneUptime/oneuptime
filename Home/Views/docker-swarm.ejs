              <!-- Slack Messages Area -->
              <div class="p-4 space-y-4 min-h-[320px]" id="docker-swarm-slack-messages">
                <!-- Main Alert Message -->
                <div class="flex gap-3" style="animation: fadeSlideIn 0.5s ease-out forwards;">
