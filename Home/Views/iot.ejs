<!DOCTYPE html>
<html lang="en" id="home">

<meta http-equiv="content-type" content="text/html;charset=utf-8" />

<head>
  <title>OneUptime | IoT Device Monitoring - Fleets, Sensors, Battery & Signal</title>
  <meta name="description"
    content="Monitor your entire IoT fleet from one dashboard: per-device health, battery, signal strength, temperature, and connectivity alerting. Standard OpenTelemetry, no proprietary agent, usage-based pricing. Open source.">
  <%- include('head', {
    enableGoogleTagManager: typeof enableGoogleTagManager !== 'undefined' ? enableGoogleTagManager : false
}) -%>
</head>

<body>
  <%- include('nav') -%>

  <main id="main-content">
    <!-- Hero Section -->
    <div class="relative isolate overflow-hidden bg-white" id="iot-hero-section">
      <!-- Subtle grid pattern background -->
      <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#f0f0f0_1px,transparent_1px),linear-gradient(to_bottom,#f0f0f0_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)]"></div>

      <!-- Grid glow effect that follows cursor - teal color -->
      <div id="iot-grid-glow" class="absolute inset-0 -z-9 pointer-events-none" style="opacity: 0; transition: opacity 0.3s ease-out; background: linear-gradient(to right, rgba(13, 148, 136, 0.3) 1px, transparent 1px), linear-gradient(to bottom, rgba(13, 148, 136, 0.3) 1px, transparent 1px); background-size: 4rem 4rem; -webkit-mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%); mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%);"></div>

      <div class="py-20 sm:py-28 lg:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-3xl text-center">
            <!-- Minimal badge -->
            <p class="text-sm font-medium text-teal-600 mb-4">OpenTelemetry Native IoT Device Monitoring</p>

            <h1 class="text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
              Your entire device fleet, one dashboard
            </h1>
            <p class="mt-6 text-lg leading-8 text-gray-600 max-w-2xl mx-auto">
              Monitor every sensor, gateway, and edge device across all your fleets. Catch dead batteries, dropped devices, and weak signals before a unit goes dark in the field — all over standard OpenTelemetry, no proprietary agent.
            </p>

            <div class="mt-10 flex items-center justify-center gap-x-6">
              <a href="/accounts/register"
                class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-800 transition-colors">
                Get started
              </a>
              <a href="/enterprise/demo" class="text-sm font-semibold text-gray-900 hover:text-gray-600 transition-colors">
                Request demo <span aria-hidden="true">&rarr;</span>
              </a>
            </div>

            <!-- Subtle feature list -->
            <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-gray-500">
              <span>Device health &amp; uptime</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Battery &amp; power</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Signal &amp; connectivity</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Fleet-wide alerts</span>
            </div>
          </div>

          <!-- Hero visual - IoT fleet overview mockup -->
          <div class="mt-16 sm:mt-20">
            <div class="relative mx-auto max-w-5xl">
              <div class="rounded-xl bg-gray-900/5 p-1.5 ring-1 ring-gray-900/10">
                <!-- IoT Dashboard Mockup -->
                <div class="rounded-lg bg-white shadow-lg overflow-hidden">
                  <!-- Header bar -->
                  <div class="bg-gray-50 px-6 py-3 flex items-center justify-between border-b border-gray-200">
                    <div class="flex items-center gap-3">
                      <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-red-400"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                        <div class="w-3 h-3 rounded-full bg-green-400"></div>
                      </div>
                      <div class="flex items-center gap-2">
                        <%- include('./Partials/icons/iot', {iconClass: 'h-4 w-4'}) %>
                        <span class="text-sm text-gray-700 font-semibold">IoT Fleet Overview</span>
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <div class="flex items-center gap-1.5 px-2.5 py-1 bg-white rounded-md border border-gray-200 text-xs text-gray-500">
                        <svg class="h-3 w-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Last 1 hour
                      </div>
                      <span class="flex items-center gap-1.5 px-2.5 py-1 bg-emerald-50 rounded-md text-xs font-medium text-emerald-600 border border-emerald-200">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                        field-fleet-eu
                      </span>
                    </div>
                  </div>

                  <!-- Dashboard content -->
                  <div class="p-5">
                    <!-- Top stats row -->
                    <div class="grid grid-cols-5 gap-3 mb-5">
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="flex items-center justify-between mb-2">
                          <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider">Devices</div>
                          <div class="w-6 h-6 rounded-md bg-teal-50 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z" />
                            </svg>
                          </div>
                        </div>
                        <div class="text-xl font-bold text-gray-900">1,248</div>
                        <div class="flex items-center gap-1 mt-1">
                          <span class="w-1 h-1 rounded-full bg-emerald-500"></span>
                          <span class="text-[10px] text-emerald-600 font-medium">across 6 fleets</span>
                        </div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="flex items-center justify-between mb-2">
                          <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider">Online</div>
                          <div class="w-6 h-6 rounded-md bg-emerald-50 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                          </div>
                        </div>
                        <div class="text-xl font-bold text-gray-900">1,231</div>
                        <div class="flex items-center gap-1.5 mt-1">
                          <span class="text-[10px] text-emerald-600 font-medium">98.6% up</span>
                          <span class="text-[10px] text-gray-400">17 offline</span>
                        </div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="flex items-center justify-between mb-2">
                          <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider">Avg Battery</div>
                          <div class="w-6 h-6 rounded-md bg-lime-50 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-lime-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M3.75 18h13.5c.621 0 1.125-.504 1.125-1.125v-9.75c0-.621-.504-1.125-1.125-1.125H3.75c-.621 0-1.125.504-1.125 1.125v9.75c0 .621.504 1.125 1.125 1.125z" />
                            </svg>
                          </div>
                        </div>
                        <div class="text-xl font-bold text-gray-900">76%</div>
                        <div class="w-full bg-gray-100 rounded-full h-1.5 mt-2">
                          <div class="bg-lime-400 h-1.5 rounded-full" style="width: 76%"></div>
                        </div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="flex items-center justify-between mb-2">
                          <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider">Avg Signal</div>
                          <div class="w-6 h-6 rounded-md bg-violet-50 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" />
                            </svg>
                          </div>
                        </div>
                        <div class="text-xl font-bold text-gray-900">-68<span class="text-xs font-medium text-gray-400 ml-1">dBm</span></div>
                        <div class="flex items-center gap-1 mt-1">
                          <span class="w-1 h-1 rounded-full bg-emerald-500"></span>
                          <span class="text-[10px] text-emerald-600 font-medium">Strong</span>
                        </div>
                      </div>
                      <div class="bg-white rounded-lg p-3.5 border border-gray-200 shadow-sm">
                        <div class="flex items-center justify-between mb-2">
                          <div class="text-[10px] font-medium text-gray-400 uppercase tracking-wider">At Risk</div>
                          <div class="w-6 h-6 rounded-md bg-amber-50 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                          </div>
                        </div>
                        <div class="text-xl font-bold text-gray-900">23</div>
                        <div class="flex items-center gap-1 mt-1">
                          <span class="w-1 h-1 rounded-full bg-amber-500"></span>
                          <span class="text-[10px] text-amber-600 font-medium">low battery / weak signal</span>
                        </div>
                      </div>
                    </div>

                    <!-- Charts row -->
                    <div class="grid grid-cols-3 gap-3 mb-5">
                      <!-- Battery & signal chart -->
                      <div class="col-span-2 bg-white rounded-lg border border-gray-200 shadow-sm p-4">
                        <div class="flex items-center justify-between mb-4">
                          <div>
                            <div class="text-sm font-semibold text-gray-800">Fleet Battery &amp; Signal</div>
                            <div class="text-[10px] text-gray-400 mt-0.5">Average across all reporting devices</div>
                          </div>
                          <div class="flex items-center gap-3">
                            <div class="flex items-center gap-1">
                              <span class="w-2 h-2 rounded-full bg-lime-500"></span>
                              <span class="text-[10px] text-gray-500">Battery</span>
                            </div>
                            <div class="flex items-center gap-1">
                              <span class="w-2 h-2 rounded-full bg-violet-500"></span>
                              <span class="text-[10px] text-gray-500">Signal</span>
                            </div>
                          </div>
                        </div>
                        <!-- SVG Chart -->
                        <svg viewBox="0 0 400 100" class="w-full h-24">
                          <defs>
                            <linearGradient id="iotBatGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                              <stop offset="0%" style="stop-color:#65a30d;stop-opacity:0.2"/>
                              <stop offset="100%" style="stop-color:#65a30d;stop-opacity:0"/>
                            </linearGradient>
                            <linearGradient id="iotSigGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                              <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:0.15"/>
                              <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:0"/>
                            </linearGradient>
                          </defs>
                          <!-- Grid lines -->
                          <line x1="0" y1="25" x2="400" y2="25" stroke="#f3f4f6" stroke-width="1"/>
                          <line x1="0" y1="50" x2="400" y2="50" stroke="#f3f4f6" stroke-width="1"/>
                          <line x1="0" y1="75" x2="400" y2="75" stroke="#f3f4f6" stroke-width="1"/>
                          <!-- Battery fill -->
                          <path d="M0,30 L25,31 L50,30 L75,32 L100,31 L125,33 L150,32 L175,34 L200,33 L225,35 L250,34 L275,36 L300,35 L325,37 L350,36 L375,38 L400,37 L400,100 L0,100 Z" fill="url(#iotBatGrad)"/>
                          <!-- Battery line -->
                          <path d="M0,30 L25,31 L50,30 L75,32 L100,31 L125,33 L150,32 L175,34 L200,33 L225,35 L250,34 L275,36 L300,35 L325,37 L350,36 L375,38 L400,37" fill="none" stroke="#65a30d" stroke-width="2" stroke-linecap="round"/>
                          <!-- Signal fill -->
                          <path d="M0,52 L25,50 L50,53 L75,49 L100,51 L125,48 L150,50 L175,47 L200,49 L225,52 L250,48 L275,50 L300,47 L325,49 L350,46 L375,48 L400,47 L400,100 L0,100 Z" fill="url(#iotSigGrad)"/>
                          <!-- Signal line -->
                          <path d="M0,52 L25,50 L50,53 L75,49 L100,51 L125,48 L150,50 L175,47 L200,49 L225,52 L250,48 L275,50 L300,47 L325,49 L350,46 L375,48 L400,47" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round"/>
                          <!-- Y-axis labels -->
                          <text x="2" y="23" fill="#9ca3af" font-size="8">100%</text>
                          <text x="2" y="48" fill="#9ca3af" font-size="8">75%</text>
                          <text x="2" y="73" fill="#9ca3af" font-size="8">50%</text>
                        </svg>
                      </div>

                      <!-- Connectivity breakdown -->
                      <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-4">
                        <div class="text-sm font-semibold text-gray-800 mb-1">Connectivity</div>
                        <div class="text-[10px] text-gray-400 mb-4">Devices reporting in the last 5 min</div>
                        <!-- Donut chart mockup -->
                        <div class="flex items-center justify-center mb-4">
                          <div class="relative">
                            <svg viewBox="0 0 80 80" class="w-20 h-20">
                              <circle cx="40" cy="40" r="30" fill="none" stroke="#e5e7eb" stroke-width="8"/>
                              <circle cx="40" cy="40" r="30" fill="none" stroke="#10b981" stroke-width="8" stroke-dasharray="185.8 188.5" stroke-dashoffset="0" transform="rotate(-90 40 40)"/>
                              <circle cx="40" cy="40" r="30" fill="none" stroke="#ef4444" stroke-width="8" stroke-dasharray="2.7 185.8" stroke-dashoffset="-185.8" transform="rotate(-90 40 40)"/>
                            </svg>
                            <div class="absolute inset-0 flex flex-col items-center justify-center">
                              <span class="text-lg font-bold text-gray-900">98.6%</span>
                              <span class="text-[8px] text-gray-400">online</span>
                            </div>
                          </div>
                        </div>
                        <div class="space-y-2">
                          <div class="flex items-center justify-between">
                            <div class="flex items-center gap-1.5">
                              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                              <span class="text-[11px] text-gray-600">Online</span>
                            </div>
                            <span class="text-[11px] font-semibold text-gray-800">1,231</span>
                          </div>
                          <div class="flex items-center justify-between">
                            <div class="flex items-center gap-1.5">
                              <span class="w-2 h-2 rounded-full bg-red-500"></span>
                              <span class="text-[11px] text-gray-600">Offline</span>
                            </div>
                            <span class="text-[11px] font-semibold text-gray-800">17</span>
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- Devices & at-risk table row -->
                    <div class="grid grid-cols-2 gap-3">
                      <!-- Devices -->
                      <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                        <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                          <span class="text-xs font-semibold text-gray-700">Devices</span>
                          <span class="text-[10px] text-gray-400">1,248 total</span>
                        </div>
                        <div class="divide-y divide-gray-100">
                          <div class="px-4 py-2 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                              <span class="text-xs font-mono text-gray-700">sensor-a17 cold-storage</span>
                            </div>
                            <div class="flex items-center gap-2">
                              <div class="flex items-center gap-1.5">
                                <span class="text-[10px] text-gray-400">BAT</span>
                                <div class="w-14 bg-gray-100 rounded-full h-1.5"><div class="bg-lime-400 h-1.5 rounded-full" style="width:82%"></div></div>
                              </div>
                              <div class="flex items-center gap-1.5">
                                <span class="text-[10px] text-gray-400">SIG</span>
                                <div class="w-14 bg-gray-100 rounded-full h-1.5"><div class="bg-violet-400 h-1.5 rounded-full" style="width:88%"></div></div>
                              </div>
                            </div>
                          </div>
                          <div class="px-4 py-2 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                              <span class="text-xs font-mono text-gray-700">gw-04 north-gate</span>
                            </div>
                            <div class="flex items-center gap-2">
                              <div class="flex items-center gap-1.5">
                                <span class="text-[10px] text-gray-400">BAT</span>
                                <div class="w-14 bg-gray-100 rounded-full h-1.5"><div class="bg-lime-400 h-1.5 rounded-full" style="width:91%"></div></div>
                              </div>
                              <div class="flex items-center gap-1.5">
                                <span class="text-[10px] text-gray-400">SIG</span>
                                <div class="w-14 bg-gray-100 rounded-full h-1.5"><div class="bg-violet-400 h-1.5 rounded-full" style="width:94%"></div></div>
                              </div>
                            </div>
                          </div>
                          <div class="px-4 py-2 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                              <span class="text-xs font-mono text-gray-700">sensor-c93 dock-bay</span>
                            </div>
                            <div class="flex items-center gap-2">
                              <div class="flex items-center gap-1.5">
                                <span class="text-[10px] text-gray-400">BAT</span>
                                <div class="w-14 bg-gray-100 rounded-full h-1.5"><div class="bg-amber-400 h-1.5 rounded-full" style="width:14%"></div></div>
                              </div>
                              <div class="flex items-center gap-1.5">
                                <span class="text-[10px] text-gray-400">SIG</span>
                                <div class="w-14 bg-gray-100 rounded-full h-1.5"><div class="bg-violet-400 h-1.5 rounded-full" style="width:61%"></div></div>
                              </div>
                            </div>
                          </div>
                          <div class="px-4 py-2 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                              <span class="text-xs font-mono text-gray-700">meter-221 substation-3</span>
                            </div>
                            <div class="flex items-center gap-2">
                              <div class="flex items-center gap-1.5">
                                <span class="text-[10px] text-gray-400">BAT</span>
                                <div class="w-14 bg-gray-100 rounded-full h-1.5"><div class="bg-lime-400 h-1.5 rounded-full" style="width:67%"></div></div>
                              </div>
                              <div class="flex items-center gap-1.5">
                                <span class="text-[10px] text-gray-400">SIG</span>
                                <div class="w-14 bg-gray-100 rounded-full h-1.5"><div class="bg-violet-400 h-1.5 rounded-full" style="width:72%"></div></div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>

                      <!-- At-risk devices -->
                      <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                        <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                          <span class="text-xs font-semibold text-gray-700">At-Risk Devices</span>
                          <span class="text-[10px] text-gray-400">3 shown</span>
                        </div>
                        <div class="divide-y divide-gray-100">
                          <div class="px-4 py-2.5 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                              <span class="text-xs font-mono text-gray-700">sensor-f02 roof-unit</span>
                            </div>
                            <span class="text-[10px] font-semibold text-red-600 uppercase">Offline 12m</span>
                          </div>
                          <div class="px-4 py-2.5 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                              <span class="text-xs font-mono text-gray-700">sensor-c93 dock-bay</span>
                            </div>
                            <span class="text-[10px] font-semibold text-amber-600 uppercase">Battery 14%</span>
                          </div>
                          <div class="px-4 py-2.5 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                              <span class="text-xs font-mono text-gray-700">gw-09 west-relay</span>
                            </div>
                            <span class="text-[10px] font-semibold text-amber-600 uppercase">-104 dBm</span>
                          </div>
                          <div class="px-4 py-2.5 flex items-center justify-between">
                            <div class="flex items-center gap-2">
                              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
