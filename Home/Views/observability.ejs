<!DOCTYPE html>
<html lang="en" id="home">

<meta http-equiv="content-type" content="text/html;charset=utf-8" />

<head>
  <title>OneUptime | Observability Platform - Logs, Metrics, Traces & More</title>
  <meta name="description"
    content="OpenTelemetry-native observability: logs, metrics, traces, exceptions, profiles, RUM, and dashboards in one open-source platform. Correlate every signal, alert on any query, and pay only for the telemetry you ingest.">
  <%- include('head', {
    enableGoogleTagManager: typeof enableGoogleTagManager !== 'undefined' ? enableGoogleTagManager : false
}) -%>
</head>

<body>
  <%- include('nav') -%>

  <main id="main-content">
    <!-- Hero Section -->
    <div class="relative isolate overflow-hidden bg-white" id="obs-hero-section">
      <!-- Subtle grid pattern background -->
      <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#f0f0f0_1px,transparent_1px),linear-gradient(to_bottom,#f0f0f0_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)]"></div>

      <!-- Grid glow effect that follows cursor - indigo color -->
      <div id="obs-grid-glow" class="absolute inset-0 -z-9 pointer-events-none" style="opacity: 0; transition: opacity 0.3s ease-out; background: linear-gradient(to right, rgba(79, 70, 229, 0.3) 1px, transparent 1px), linear-gradient(to bottom, rgba(79, 70, 229, 0.3) 1px, transparent 1px); background-size: 4rem 4rem; -webkit-mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%); mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%);"></div>

      <div class="py-20 sm:py-28 lg:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-3xl text-center">
            <!-- Minimal badge -->
            <p class="text-sm font-medium text-indigo-600 mb-4">OpenTelemetry-Native Observability Platform</p>

            <h1 class="text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
              All your telemetry. One platform.
            </h1>
            <p class="mt-6 text-lg leading-8 text-gray-600 max-w-2xl mx-auto">
              Logs, metrics, traces, exceptions, profiles, and real user monitoring &mdash; ingested over standard OpenTelemetry, stored together, and correlated so a spike in one signal takes you straight to the cause in another. Open source, and priced per GB instead of per host.
            </p>

            <div class="mt-10 flex items-center justify-center gap-x-6">
              <a href="/accounts/register"
                class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-800 transition-colors">
                Get started
              </a>
              <a href="/enterprise/demo" class="text-sm font-semibold text-gray-900 hover:text-gray-600 transition-colors">
                Request demo <span aria-hidden="true">&rarr;</span>
              </a>
            </div>

            <!-- Subtle feature list -->
            <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-gray-500">
              <span>Logs</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Metrics</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Traces</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Exceptions</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Profiles</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>RUM</span>
            </div>
          </div>

          <!-- Hero visual - Trace + correlated signals mockup -->
          <div class="mt-16 sm:mt-20">
            <div class="relative mx-auto max-w-5xl">
              <div class="rounded-xl bg-gray-900/5 p-1.5 ring-1 ring-gray-900/10">
                <!-- Observability Dashboard Mockup -->
                <div class="rounded-lg bg-white shadow-lg overflow-hidden">
                  <!-- Header bar -->
                  <div class="bg-gray-50 px-6 py-3 flex items-center justify-between border-b border-gray-200">
                    <div class="flex items-center gap-3">
                      <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-red-400"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                        <div class="w-3 h-3 rounded-full bg-green-400"></div>
                      </div>
                      <div class="flex items-center gap-2">
                        <%- include('./Partials/icons/observability', {iconClass: 'h-4 w-4'}) %>
                        <span class="text-sm text-gray-700 font-semibold">Trace &middot; POST /api/checkout</span>
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <div class="flex items-center gap-1.5 px-2.5 py-1 bg-white rounded-md border border-gray-200 text-xs text-gray-500">
                        <svg class="h-3 w-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        842 ms &middot; 14 spans
                      </div>
                      <span class="flex items-center gap-1.5 px-2.5 py-1 bg-red-50 rounded-md text-xs font-medium text-red-600 border border-red-200">
                        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                        error
                      </span>
                    </div>
                  </div>

                  <!-- Dashboard content -->
                  <div class="p-5">
                    <!-- Waterfall -->
                    <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-4 mb-4">
                      <div class="text-sm font-semibold text-gray-800 mb-3">Waterfall</div>
                      <div class="space-y-2">
                        <div class="flex items-center gap-3">
                          <span class="w-32 text-[11px] font-mono text-gray-600 truncate">web-frontend</span>
                          <div class="flex-1 relative h-4 bg-gray-50 rounded">
                            <div class="absolute h-4 rounded bg-indigo-400" style="left:0%;width:96%"></div>
                          </div>
                          <span class="w-14 text-right text-[10px] text-gray-400">842 ms</span>
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="w-32 text-[11px] font-mono text-gray-600 truncate">&nbsp;&nbsp;checkout-service</span>
                          <div class="flex-1 relative h-4 bg-gray-50 rounded">
                            <div class="absolute h-4 rounded bg-indigo-300" style="left:6%;width:84%"></div>
                          </div>
                          <span class="w-14 text-right text-[10px] text-gray-400">718 ms</span>
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="w-32 text-[11px] font-mono text-gray-600 truncate">&nbsp;&nbsp;&nbsp;&nbsp;payments-api</span>
                          <div class="flex-1 relative h-4 bg-gray-50 rounded">
                            <div class="absolute h-4 rounded bg-red-400" style="left:22%;width:58%"></div>
                          </div>
                          <span class="w-14 text-right text-[10px] text-red-500 font-medium">497 ms</span>
                        </div>
                        <div class="flex items-center gap-3">
                          <span class="w-32 text-[11px] font-mono text-gray-600 truncate">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;postgres</span>
                          <div class="flex-1 relative h-4 bg-gray-50 rounded">
                            <div class="absolute h-4 rounded bg-sky-300" style="left:30%;width:12%"></div>
                          </div>
                          <span class="w-14 text-right text-[10px] text-gray-400">104 ms</span>
                        </div>
                      </div>
                    </div>

                    <!-- Correlated signals row -->
                    <div class="grid grid-cols-2 gap-3">
                      <!-- Correlated logs -->
                      <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                        <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                          <span class="text-xs font-semibold text-gray-700">Logs for this trace</span>
                          <span class="text-[10px] text-gray-400">same trace.id</span>
                        </div>
                        <div class="divide-y divide-gray-100 font-mono">
                          <div class="px-4 py-2 text-[10px] text-gray-500"><span class="text-gray-400">14:02:11.204</span> <span class="text-sky-600">INFO</span> charge requested order=8841</div>
                          <div class="px-4 py-2 text-[10px] text-gray-500"><span class="text-gray-400">14:02:11.688</span> <span class="text-amber-600">WARN</span> upstream retry attempt=2</div>
                          <div class="px-4 py-2 text-[10px] bg-red-50/50 text-gray-600"><span class="text-gray-400">14:02:11.701</span> <span class="text-red-600 font-bold">ERROR</span> gateway timeout after 450ms</div>
                        </div>
                      </div>

                      <!-- Correlated metric + exception -->
                      <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
                        <div class="px-4 py-2.5 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                          <span class="text-xs font-semibold text-gray-700">payments-api &middot; error rate</span>
                          <span class="text-[10px] text-red-500 font-medium">&uarr; 4.2%</span>
                        </div>
                        <div class="p-3">
                          <svg viewBox="0 0 400 70" class="w-full h-16">
                            <defs>
                              <linearGradient id="obsErrGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                                <stop offset="0%" style="stop-color:#ef4444;stop-opacity:0.2"/>
                                <stop offset="100%" style="stop-color:#ef4444;stop-opacity:0"/>
                              </linearGradient>
                            </defs>
                            <line x1="0" y1="23" x2="400" y2="23" stroke="#f3f4f6" stroke-width="1"/>
                            <line x1="0" y1="46" x2="400" y2="46" stroke="#f3f4f6" stroke-width="1"/>
                            <path d="M0,60 L40,59 L80,60 L120,58 L160,59 L200,57 L240,58 L280,40 L320,22 L360,14 L400,12 L400,70 L0,70 Z" fill="url(#obsErrGrad)"/>
                            <path d="M0,60 L40,59 L80,60 L120,58 L160,59 L200,57 L240,58 L280,40 L320,22 L360,14 L400,12" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/>
                          </svg>
                          <div class="mt-2 flex items-center justify-between p-2 bg-red-50 rounded-lg border border-red-100">
                            <span class="text-[11px] font-mono text-gray-600">GatewayTimeoutError</span>
                            <span class="text-[10px] text-red-600 font-semibold">28 occurrences &middot; grouped</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('logo-roll') -%>

    <!-- How It Works Section -->
    <div class="relative bg-gray-50 py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <p class="text-sm font-medium text-indigo-600 uppercase tracking-wide mb-3">How It Works</p>
          <h2 class="text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl">
            If it speaks OpenTelemetry, it works
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            No proprietary agent, no vendor SDK to adopt. Point your existing instrumentation at OneUptime and keep everything portable.
          </p>
        </div>

        <div class="mx-auto max-w-5xl">
          <!-- Connecting line for desktop -->
          <div class="hidden lg:block relative">
            <div class="absolute top-8 left-[calc(12.5%+24px)] right-[calc(12.5%+24px)] h-px bg-indigo-200"></div>
          </div>

          <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Step 1 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-600 ring-2 ring-indigo-600">1</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Point your SDK at OneUptime</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Set <code class="text-xs bg-gray-100 px-1 py-0.5 rounded">OTEL_EXPORTER_OTLP_ENDPOINT</code> and an ingest-token header. OTLP over HTTP or gRPC, with official OpenTelemetry SDKs in 11+ languages.</p>
            </div>

            <!-- Step 2 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 7.5h-.75A2.25 2.25 0 004.5 9.75v7.5a2.25 2.25 0 002.25 2.25h7.5a2.25 2.25 0 002.25-2.25v-7.5a2.25 2.25 0 00-2.25-2.25h-.75m0-3l-3-3m0 0l-3 3m3-3v11.25m6-2.25h.75a2.25 2.25 0 012.25 2.25v7.5a2.25 2.25 0 01-2.25 2.25h-7.5a2.25 2.25 0 01-2.25-2.25v-.75" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-600 ring-2 ring-indigo-600">2</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Or keep your shippers</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Dedicated endpoints for Fluentd and syslog bring in logs from hundreds of sources &mdash; Fluent Bit ships over its OpenTelemetry output. Profilers that speak Pyroscope's pprof push straight in.</p>
            </div>

            <!-- Step 3 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 5.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-600 ring-2 ring-indigo-600">3</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Query at any scale</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Telemetry lands in ClickHouse-backed storage built for petabyte scale. Search logs in milliseconds with full-text or SQL &mdash; no rehydration, ever.</p>
            </div>

            <!-- Step 4 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-600 ring-2 ring-indigo-600">4</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Alert on any signal</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Turn any telemetry query into a monitor &mdash; threshold or anomaly-based &mdash; wired to escalation policies, incidents, and status pages in the same product.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Why OneUptime Section -->
    <div class="relative bg-white py-24 sm:py-32 overflow-hidden">

      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <!-- Section header -->
        <div class="mx-auto max-w-2xl text-center mb-20">
          <div class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-1.5 text-sm font-medium text-indigo-700 ring-1 ring-inset ring-indigo-600/20 mb-6">
            <svg class="h-4 w-4 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
            <span class="text-sm font-medium text-indigo-700">Why OneUptime for observability</span>
          </div>
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl">
            Signals that talk to each other
          </h2>
          <p class="mt-6 text-lg leading-8 text-gray-600">
            Separate logging, metrics, and tracing vendors mean every incident starts with copy-pasting timestamps between browser tabs. When every signal lives in one platform, the spike, the trace, the log line, and the exception are one click apart.
          </p>
        </div>

        <!-- Feature blocks -->
        <div class="space-y-24">

          <!-- Feature 1: Correlation -->
          <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
            <div class="relative">
              <div class="flex items-center gap-4 mb-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50 ring-1 ring-indigo-200">
                  <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                  </svg>
                </div>
                <span class="text-sm font-semibold text-indigo-600 uppercase tracking-wide">Cross-Signal Correlation</span>
              </div>
              <h3 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">From symptom to cause without switching tabs</h3>
              <p class="mt-4 text-lg text-gray-600">Every log line carries its trace context, every exception points at its span, every metric shares the same resource attributes. Jump from a slow trace to the exact logs it emitted, from an error-rate spike to the grouped exception behind it &mdash; because it's one store, not three products glued together with timestamps.</p>
              <ul class="mt-6 space-y-3">
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="h-5 w-5 text-indigo-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Trace &rarr; logs &rarr; metrics &rarr; exceptions, one click each way
                </li>
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="h-5 w-5 text-indigo-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Intelligent error grouping with full stack traces
                </li>
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="h-5 w-5 text-indigo-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  RUM sessions link browser clicks to the backend traces behind them
                </li>
              </ul>
              <a href="/accounts/register" class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800 transition-colors mt-8">
                Get started
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>
            </div>
            <div class="mt-12 lg:mt-0">
              <div class="relative">
                <div class="absolute -inset-4 bg-gray-100/50 rounded-3xl blur-2xl"></div>

                <!-- Correlation Mockup -->
                <div class="relative bg-white rounded-xl shadow-lg overflow-hidden max-w-md mx-auto border border-gray-200">
                  <div class="bg-gray-50 px-4 py-2.5 flex items-center gap-3 border-b border-gray-100">
                    <div class="flex gap-1.5">
                      <div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div>
                      <div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div>
                      <div class="w-2.5 h-2.5 rounded-full bg-gray-300"></div>
                    </div>
                    <div class="flex-1 text-center">
                      <span class="text-xs text-gray-400">Span &middot; charge-card</span>
                    </div>
                  </div>
                  <div class="p-4 space-y-3">
                    <div class="p-3 bg-red-50 rounded-lg border border-red-200">
                      <div class="flex items-center justify-between mb-1">
                        <span class="text-xs font-mono text-gray-700">payments-api &middot; charge-card</span>
                        <span class="text-[10px] font-bold text-red-600 uppercase">error</span>
                      </div>
                      <div class="text-[10px] text-gray-500">span 4c9a&hellip; &middot; 497 ms &middot; retry=2</div>
                    </div>
                    <div class="flex items-center gap-2 text-[10px] text-gray-400 uppercase tracking-wider font-semibold">
                      <span class="flex-1 h-px bg-gray-100"></span>
                      correlated signals
                      <span class="flex-1 h-px bg-gray-100"></span>
                    </div>
                    <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg border border-gray-200">
