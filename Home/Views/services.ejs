<!DOCTYPE html>
<html lang="en" id="home">

<meta http-equiv="content-type" content="text/html;charset=utf-8" />

<head>
  <title>OneUptime | Service Catalog - Map, Own & Monitor Every Service</title>
  <meta name="description"
    content="A single catalog of every service you run. Assign owners, group by labels, and connect each service to its logs, traces, metrics, and incidents. Open source.">
  <%- include('head', {
    enableGoogleTagManager: typeof enableGoogleTagManager !== 'undefined' ? enableGoogleTagManager : false
}) -%>
</head>

<body>
  <%- include('nav') -%>

  <main id="main-content">
    <!-- Hero Section -->
    <div class="relative isolate overflow-hidden bg-white" id="services-hero-section">
      <!-- Subtle grid pattern background -->
      <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#f0f0f0_1px,transparent_1px),linear-gradient(to_bottom,#f0f0f0_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)]"></div>

      <!-- Grid glow effect that follows cursor -->
      <div id="services-grid-glow" class="absolute inset-0 -z-9 pointer-events-none" style="opacity: 0; transition: opacity 0.3s ease-out; background: linear-gradient(to right, rgba(99, 102, 241, 0.3) 1px, transparent 1px), linear-gradient(to bottom, rgba(99, 102, 241, 0.3) 1px, transparent 1px); background-size: 4rem 4rem; -webkit-mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%); mask-image: radial-gradient(circle 250px at var(--mouse-x, 50%) var(--mouse-y, 50%), black 0%, transparent 100%);"></div>

      <div class="py-20 sm:py-28 lg:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-3xl text-center">
            <p class="text-sm font-medium text-indigo-600 mb-4">Service Catalog</p>

            <h1 class="text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
              Every service you run, in one catalog
            </h1>
            <p class="mt-6 text-lg leading-8 text-gray-600 max-w-2xl mx-auto">
              Map ownership. Group by team or tier. Link each service to the logs, traces, metrics, and incidents that belong to it — so the on-call always knows who owns what and where to look.
            </p>

            <div class="mt-10 flex items-center justify-center gap-x-6">
              <a href="/accounts/register"
                class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-800 transition-colors">
                Get started
              </a>
              <a href="/enterprise/demo" class="text-sm font-semibold text-gray-900 hover:text-gray-600 transition-colors">
                Request demo <span aria-hidden="true">&rarr;</span>
              </a>
            </div>

            <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-gray-500">
              <span>Owner mapping</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Label grouping</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Linked telemetry</span>
              <span class="hidden sm:inline text-gray-300">|</span>
              <span>Incident attribution</span>
            </div>
          </div>

          <!-- Hero visual - Service catalog mockup -->
          <div class="mt-16 sm:mt-20">
            <div class="relative mx-auto max-w-5xl">
              <div class="rounded-xl bg-gray-900/5 p-1.5 ring-1 ring-gray-900/10">
                <div class="rounded-lg bg-white shadow-lg overflow-hidden">
                  <!-- Header bar -->
                  <div class="bg-gray-50 px-6 py-3 flex items-center justify-between border-b border-gray-200">
                    <div class="flex items-center gap-3">
                      <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-red-400"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                        <div class="w-3 h-3 rounded-full bg-green-400"></div>
                      </div>
                      <div class="flex items-center gap-2">
                        <%- include('./Partials/icons/services', {iconClass: 'h-4 w-4'}) %>
                        <span class="text-sm text-gray-700 font-semibold">Services</span>
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <div class="flex items-center gap-1.5 px-2.5 py-1 bg-white rounded-md border border-gray-200 text-xs text-gray-500">
                        <svg class="h-3 w-3 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.34-4.34M19 11a8 8 0 11-16 0 8 8 0 0116 0z" />
                        </svg>
                        Search services
                      </div>
                      <span class="flex items-center gap-1.5 px-2.5 py-1 bg-indigo-50 rounded-md text-xs font-medium text-indigo-600 border border-indigo-200">
                        24 services
                      </span>
                    </div>
                  </div>

                  <!-- Catalog content -->
                  <div class="p-5">
                    <!-- Filter bar -->
                    <div class="flex flex-wrap items-center gap-2 mb-4">
                      <span class="text-xs font-medium text-gray-500 uppercase tracking-wide mr-1">Labels:</span>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700 ring-1 ring-blue-200">payments</span>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200">tier-1</span>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-50 text-amber-700 ring-1 ring-amber-200">customer-facing</span>
                      <span class="text-xs text-gray-400 ml-auto">3 of 24 shown</span>
                    </div>

                    <!-- Services table -->
                    <div class="border border-gray-200 rounded-lg overflow-hidden">
                      <div class="grid grid-cols-12 px-4 py-2.5 bg-gray-50 border-b border-gray-200 text-[10px] font-semibold text-gray-500 uppercase tracking-wider">
                        <div class="col-span-4">Service</div>
                        <div class="col-span-3">Owners</div>
                        <div class="col-span-3">Labels</div>
                        <div class="col-span-2">Status</div>
                      </div>

                      <!-- Row 1 -->
                      <div class="grid grid-cols-12 px-4 py-3 border-b border-gray-100 items-center hover:bg-gray-50 transition-colors">
                        <div class="col-span-4 flex items-center gap-2.5">
                          <span class="w-2 h-2 rounded-full bg-indigo-500"></span>
                          <span class="text-sm font-medium text-gray-900">checkout-api</span>
                        </div>
                        <div class="col-span-3 flex items-center -space-x-2">
                          <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-rose-100 text-[10px] font-semibold text-rose-700 ring-2 ring-white">JL</span>
                          <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-amber-100 text-[10px] font-semibold text-amber-700 ring-2 ring-white">SK</span>
                          <span class="ml-3 text-xs text-gray-500">payments-team</span>
                        </div>
                        <div class="col-span-3 flex gap-1">
                          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-blue-50 text-blue-700">payments</span>
                          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-emerald-50 text-emerald-700">tier-1</span>
                        </div>
                        <div class="col-span-2">
                          <span class="inline-flex items-center gap-1.5 text-xs text-emerald-600">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                            Healthy
                          </span>
                        </div>
                      </div>

                      <!-- Row 2 -->
                      <div class="grid grid-cols-12 px-4 py-3 border-b border-gray-100 items-center hover:bg-gray-50 transition-colors">
                        <div class="col-span-4 flex items-center gap-2.5">
                          <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                          <span class="text-sm font-medium text-gray-900">orders-worker</span>
                        </div>
                        <div class="col-span-3 flex items-center -space-x-2">
                          <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-violet-100 text-[10px] font-semibold text-violet-700 ring-2 ring-white">MR</span>
                          <span class="ml-3 text-xs text-gray-500">payments-team</span>
                        </div>
                        <div class="col-span-3 flex gap-1">
                          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-blue-50 text-blue-700">payments</span>
                          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-emerald-50 text-emerald-700">tier-1</span>
                        </div>
                        <div class="col-span-2">
                          <span class="inline-flex items-center gap-1.5 text-xs text-amber-600">
                            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                            Degraded
                          </span>
                        </div>
                      </div>

                      <!-- Row 3 -->
                      <div class="grid grid-cols-12 px-4 py-3 items-center hover:bg-gray-50 transition-colors">
                        <div class="col-span-4 flex items-center gap-2.5">
                          <span class="w-2 h-2 rounded-full bg-cyan-500"></span>
                          <span class="text-sm font-medium text-gray-900">web-storefront</span>
                        </div>
                        <div class="col-span-3 flex items-center -space-x-2">
                          <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-blue-100 text-[10px] font-semibold text-blue-700 ring-2 ring-white">AT</span>
                          <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-pink-100 text-[10px] font-semibold text-pink-700 ring-2 ring-white">RD</span>
                          <span class="ml-3 text-xs text-gray-500">frontend-team</span>
                        </div>
                        <div class="col-span-3 flex gap-1">
                          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-50 text-amber-700">customer-facing</span>
                          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-emerald-50 text-emerald-700">tier-1</span>
                        </div>
                        <div class="col-span-2">
                          <span class="inline-flex items-center gap-1.5 text-xs text-emerald-600">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                            Healthy
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- How It Works Section -->
    <div class="relative bg-gray-50 py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-16">
          <p class="text-sm font-medium text-indigo-600 uppercase tracking-wide mb-3">How It Works</p>
          <h2 class="text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl">
            From scattered repos to a clear catalog
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            Define a service, hand it an owner, and the rest of OneUptime — logs, traces, metrics, incidents — wires itself up.
          </p>
        </div>

        <div class="mx-auto max-w-5xl">
          <div class="hidden lg:block relative">
            <div class="absolute top-8 left-[calc(12.5%+24px)] right-[calc(12.5%+24px)] h-px bg-indigo-200"></div>
          </div>

          <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Step 1 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-700 ring-2 ring-indigo-600">1</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Create the service</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Add it from the dashboard or via the API. Give it a name, a color, and a short description.</p>
            </div>

            <!-- Step 2 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-700 ring-2 ring-indigo-600">2</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Assign owners</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Hand the service to a team, a list of users, or both. Owners drive routing for incidents and alerts.</p>
            </div>

            <!-- Step 3 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 6h.008v.008H6V6z" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-700 ring-2 ring-indigo-600">3</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Group with labels</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Tier-1, customer-facing, payments, backend — pick the dimensions that matter and filter the catalog by them.</p>
            </div>

            <!-- Step 4 -->
            <div class="text-center">
              <div class="relative inline-flex items-center justify-center h-16 w-16 rounded-full bg-indigo-600 text-white mb-6 shadow-sm">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                </svg>
                <span class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-white text-xs font-semibold text-indigo-700 ring-2 ring-indigo-600">4</span>
              </div>
              <h3 class="text-base font-semibold text-gray-900 mb-2">Telemetry wires itself</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Logs, traces, metrics, and incidents tagged with the service link back automatically — no extra config.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Why OneUptime Section -->
    <div class="relative bg-white py-24 sm:py-32 overflow-hidden">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center mb-20">
          <div class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-1.5 text-sm font-medium text-indigo-700 ring-1 ring-inset ring-indigo-600/20 mb-6">
            <svg class="h-4 w-4 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
            <span class="text-sm font-medium text-indigo-700">Why OneUptime for Services</span>
          </div>
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl lg:text-5xl">
            A catalog that's actually wired in
          </h2>
          <p class="mt-6 text-lg leading-8 text-gray-600">
            Most catalogs are spreadsheets. This one is the same source of truth your on-call, your incidents, and your dashboards already use.
          </p>
        </div>

        <div class="space-y-24">

          <!-- Feature 1: Ownership -->
          <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
            <div class="relative">
              <div class="flex items-center gap-4 mb-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50 ring-1 ring-indigo-200">
                  <svg class="h-5 w-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                  </svg>
                </div>
                <span class="text-sm font-semibold text-indigo-600 uppercase tracking-wide">Ownership</span>
              </div>
              <h3 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Every service has a name on it</h3>
              <p class="mt-4 text-lg text-gray-600">Assign teams, users, or both. Owners drive incident routing, on-call rotation, and approval flows — so a 3am page always reaches someone who can fix it.</p>
              <ul class="mt-6 space-y-3">
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="h-5 w-5 text-indigo-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Team and user owners, both at once
                </li>
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="h-5 w-5 text-indigo-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Bulk-assign owners across many services at once
                </li>
                <li class="flex items-center gap-3 text-gray-600">
                  <svg class="h-5 w-5 text-indigo-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  Owners feed incident routing and on-call escalations
                </li>
              </ul>
            </div>

            <div class="mt-12 lg:mt-0">
              <div class="rounded-xl bg-gray-900/5 p-1.5 ring-1 ring-gray-900/10">
                <div class="rounded-lg bg-white shadow-lg overflow-hidden">
                  <div class="px-4 py-3 border-b border-gray-200 bg-gray-50">
                    <span class="text-xs font-semibold text-gray-700">checkout-api &middot; Owners</span>
                  </div>
                  <div class="p-4 space-y-3">
                    <div class="flex items-center gap-3">
                      <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-indigo-100 text-xs font-semibold text-indigo-700">PT</span>
                      <div class="flex-1">
                        <p class="text-sm font-medium text-gray-900">payments-team</p>
                        <p class="text-xs text-gray-500">Team &middot; 6 members</p>
                      </div>
                      <span class="text-[10px] font-medium text-indigo-700 bg-indigo-50 px-2 py-0.5 rounded">Primary</span>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-rose-100 text-xs font-semibold text-rose-700">JL</span>
                      <div class="flex-1">
                        <p class="text-sm font-medium text-gray-900">Jamie Lee</p>
                        <p class="text-xs text-gray-500">User &middot; Backend lead</p>
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-amber-100 text-xs font-semibold text-amber-700">SK</span>
                      <div class="flex-1">
                        <p class="text-sm font-medium text-gray-900">Sarah Kim</p>
                        <p class="text-xs text-gray-500">User &middot; SRE</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Feature 2: Labels -->
          <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-center">
            <div class="order-2 lg:order-1 mt-12 lg:mt-0">
              <div class="rounded-xl bg-gray-900/5 p-1.5 ring-1 ring-gray-900/10">
                <div class="rounded-lg bg-white shadow-lg overflow-hidden">
                  <div class="px-4 py-3 border-b border-gray-200 bg-gray-50 flex items-center justify-between">
                    <span class="text-xs font-semibold text-gray-700">Filter services</span>
                    <span class="text-[10px] text-gray-500">7 of 24 match</span>
                  </div>
                  <div class="p-4">
                    <div class="text-[10px] font-medium text-gray-500 uppercase tracking-wider mb-2">Selected labels</div>
                    <div class="flex flex-wrap gap-1.5 mb-4">
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700 ring-1 ring-blue-200">payments</span>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200">tier-1</span>
                    </div>
