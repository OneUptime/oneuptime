## Hash tuning for many/long server names. Can be overridden via env vars.
## Defaults are provided by envsubst-on-templates.sh if not set.
server_names_hash_bucket_size ${SERVER_NAMES_HASH_BUCKET_SIZE};
server_names_hash_max_size ${SERVER_NAMES_HASH_MAX_SIZE};

## Upstream connection pools for the app backend. The block below is kept only
## when NGINX_UPSTREAM_KEEPALIVE=true (Kubernetes, where the backend is a stable
## Service ClusterIP); envsubst-on-templates.sh strips it otherwise so
## docker-compose keeps the resolver + per-request $backend_app path that
## tolerates the app container changing IP. proxy_pass targets follow the same
## toggle via ${BACKEND_APP_TARGET} / ${BACKEND_APP_GRPC_TARGET}.
# BEGIN upstream-keepalive
upstream backend_app {
    server ${SERVER_APP_HOSTNAME}:${APP_PORT};
    keepalive ${NGINX_UPSTREAM_KEEPALIVE_CONNECTIONS};
    # Must stay BELOW the backend's keepAliveTimeout (75s, set in
    # Common/Server/Utils/Express.ts) so nginx retires an idle pooled socket
    # before the app does — otherwise nginx can reuse a socket the app already
    # closed and 502 a request it cannot safely retry (e.g. a POST ingest).
    keepalive_timeout 60s;
    keepalive_requests 10000;
}
upstream backend_app_grpc {
    server ${SERVER_APP_HOSTNAME}:4317;
    keepalive ${NGINX_UPSTREAM_KEEPALIVE_CONNECTIONS};
}
# END upstream-keepalive

